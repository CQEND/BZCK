+    private HolidayDetailDTO getHolidayDetailDTO(Loan loan, LocalDate businessDate) {
+        if (loanUtilService == null || loan == null || loan.getOfficeId() == null) {
+            return null;
+        }
+        LocalDate holidayStartDate = loan.getDisbursementDate();
+        if (holidayStartDate == null || DateUtils.isAfter(holidayStartDate, businessDate)) {
