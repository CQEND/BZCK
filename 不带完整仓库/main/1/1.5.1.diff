+    private long calculateOverdueDays(LocalDate overdueSinceDate, LocalDate businessDate, HolidayDetailDTO holidayDetailDTO) {
+        if (overdueSinceDate == null) {
+            return 0L;
+        }
+        if (holidayDetailDTO == null) {
+            return Math.max(DateUtils.getDifferenceInDays(overdueSinceDate, businessDate), 0L);
+        }
+        return HolidayUtil.getBusinessDaysBetween(overdueSinceDate, businessDate, holidayDetailDTO.isHolidayEnabled(),
+                holidayDetailDTO.getHolidays(), holidayDetailDTO.getWorkingDays());
+    }
+
+    private LocalDate calculateDelinquentDate(LocalDate overdueSinceDate, Integer graceDays, HolidayDetailDTO holidayDetailDTO) {
+        if (overdueSinceDate == null) {
+            return null;
+        }
+        long effectiveGraceDays = graceDays == null ? 0L : graceDays.longValue();
+        if (holidayDetailDTO == null) {
+            return overdueSinceDate.plusDays(effectiveGraceDays);
+        }
+        return HolidayUtil.addBusinessDays(overdueSinceDate, effectiveGraceDays, holidayDetailDTO.isHolidayEnabled(),
+                holidayDetailDTO.getHolidays(), holidayDetailDTO.getWorkingDays());
+    }
+
+    private long calculatePausedDays(List<LoanDelinquencyActionData> effectiveDelinquencyList, LocalDate overdueSinceDate,
+            LocalDate businessDate, HolidayDetailDTO holidayDetailDTO) {
+        if (effectiveDelinquencyList == null || effectiveDelinquencyList.isEmpty()) {
+            return 0L;
+        }
+        if (holidayDetailDTO == null) {
+            Long pausedDays = delinquencyEffectivePauseHelper.getPausedDaysWithinRange(effectiveDelinquencyList, overdueSinceDate,
+                    businessDate);
+            return pausedDays == null ? 0L : pausedDays;
+        }
+        return effectiveDelinquencyList.stream().mapToLong(pausePeriod -> calculatePausedBusinessDaysWithinRange(pausePeriod,
+                overdueSinceDate, businessDate, holidayDetailDTO)).sum();
+    }
+
+    private long calculatePausedBusinessDaysWithinRange(LoanDelinquencyActionData pausePeriod, LocalDate overdueSinceDate,
+            LocalDate businessDate, HolidayDetailDTO holidayDetailDTO) {
+        if (pausePeriod == null || overdueSinceDate == null || businessDate == null || !overdueSinceDate.isBefore(businessDate)) {
+            return 0L;
+        }
+        LocalDate pauseStart = pausePeriod.getStartDate();
+        LocalDate pauseEnd = pausePeriod.getEndDate() == null ? businessDate : pausePeriod.getEndDate();
+        if (pauseStart == null || !pauseStart.isBefore(businessDate)) {
+            return 0L;
+        }
+        if (!pauseEnd.isAfter(overdueSinceDate)) {
+            return 0L;
+        }
+        LocalDate overlapStart = pauseStart.isAfter(overdueSinceDate) ? pauseStart : overdueSinceDate;
+        LocalDate overlapEnd = pauseEnd.isBefore(businessDate) ? pauseEnd : businessDate;
+        if (!overlapStart.isBefore(overlapEnd)) {
+            return 0L;
+        }
+        return HolidayUtil.getBusinessDaysBetween(overlapStart, overlapEnd, holidayDetailDTO.isHolidayEnabled(),
+                holidayDetailDTO.getHolidays(), holidayDetailDTO.getWorkingDays());
+    }
