+        if (fromDate == null || toDate == null) {
+            return 0L;
+        }
+        long count = 0;
+        LocalDate date = fromDate;
+        while (!date.isAfter(toDate)) {
+            boolean isHoliday = holidayRepositoryWrapper.isHoliday(officeId, date);
+            boolean isWorkingDay = workingDaysRepositoryWrapper.isWorkingDay(date);
+            if (isHoliday || !isWorkingDay) {
+                count++;
+            }
+            date = date.plusDays(1);
+        }
+        return count;
+    }
+}
