++import lombok.RequiredArgsConstructor;
++import org.apache.fineract.organisation.holiday.domain.HolidayRepositoryWrapper;
++import org.apache.fineract.organisation.workingdays.domain.WorkingDaysRepositoryWrapper;
++import org.springframework.stereotype.Service;
++
++@Service
++@RequiredArgsConstructor
++public class DelinquencyNonWorkingDaysServiceImpl implements DelinquencyNonWorkingDaysService {
++
++    private final HolidayRepositoryWrapper holidayRepositoryWrapper;
++    private final WorkingDaysRepositoryWrapper workingDaysRepositoryWrapper;
++
++    @Override
++    public long countNonWorkingDays(Long officeId, LocalDate fromDate, LocalDate toDate) {
++        if (fromDate == null || toDate == null) {
++            return 0L;
++        }
++        long count = 0;
++        LocalDate date = fromDate;
++        while (!date.isAfter(toDate)) {
++            boolean isHoliday = holidayRepositoryWrapper.isHoliday(officeId, date);
++            boolean isWorkingDay = workingDaysRepositoryWrapper.isWorkingDay(date);
++            if (isHoliday || !isWorkingDay) {
++                count++;
++            }
++            date = date.plusDays(1);
++        }
++        return count;
++    }
++}
