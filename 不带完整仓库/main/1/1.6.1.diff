+    @Transactional
+    @Override
+    public void batchUpdateFirstRepaymentDate(final List<Long> loanIds, final LocalDate newRepaymentDate, final Long loanProductId) {
+        validateBatchUpdateFirstRepaymentDateRequest(loanIds, newRepaymentDate, loanProductId);
+
+        final List<Loan> loans = this.loanRepository.findAllById(loanIds);
+        final Map<Long, Loan> loansById = new HashMap<>();
+        for (Loan loan : loans) {
+            loansById.put(loan.getId(), loan);
+        }
+
+        for (Long loanId : loanIds) {
+            if (!loansById.containsKey(loanId)) {
+                throw batchUpdateFirstRepaymentDateException(
+                        "error.msg.loan.batch.update.first.repayment.date.loan.not.found",
+                        "Loan " + loanId + " was not found.", "loanIds", loanId, loanId);
+            }
+        }
+
+        final List<Loan> loansToUpdate = new ArrayList<>();
+        for (Long loanId : loanIds) {
+            final Loan loan = loansById.get(loanId);
+            validateLoanForBatchUpdateFirstRepaymentDate(loan, newRepaymentDate, loanProductId);
+            loan.setExpectedFirstRepaymentOnDate(newRepaymentDate);
+            loansToUpdate.add(loan);
+        }
+
+        this.loanRepository.saveAll(loansToUpdate);
+    }
+
+    private void validateBatchUpdateFirstRepaymentDateRequest(final List<Long> loanIds, final LocalDate newRepaymentDate,
+            final Long loanProductId) {
+        final List<ApiParameterError> dataValidationErrors = new ArrayList<>();
+
+        if (loanIds == null || loanIds.isEmpty()) {
+            dataValidationErrors.add(ApiParameterError.parameterError(
+                    "error.msg.loan.batch.update.first.repayment.date.loan.ids.required", "At least one loanId must be provided.",
+                    "loanIds", loanIds));
+        } else {
+            final Set<Long> uniqueLoanIds = new HashSet<>();
+            for (Long loanId : loanIds) {
+                if (loanId == null) {
+                    dataValidationErrors.add(ApiParameterError.parameterError(
+                            "error.msg.loan.batch.update.first.repayment.date.loan.id.required",
+                            "Loan ids must not contain null values.", "loanIds", loanIds));
+                    break;
+                }
+                if (!uniqueLoanIds.add(loanId)) {
+                    dataValidationErrors.add(ApiParameterError.parameterError(
+                            "error.msg.loan.batch.update.first.repayment.date.loan.ids.duplicate",
+                            "Loan ids must be unique. Duplicate loanId found: " + loanId + ".", "loanIds", loanIds, loanId));
+                    break;
+                }
+            }
+        }
+
+        if (newRepaymentDate == null) {
+            dataValidationErrors.add(ApiParameterError.parameterError(
+                    "error.msg.loan.batch.update.first.repayment.date.date.required", "A new repayment date must be provided.",
+                    "newRepaymentDate", null));
+        }
+        if (loanProductId == null) {
+            dataValidationErrors.add(ApiParameterError.parameterError(
+                    "error.msg.loan.batch.update.first.repayment.date.loan.product.id.required",
+                    "A loan product id must be provided.", "loanProductId", null));
+        }
+
+        if (!dataValidationErrors.isEmpty()) {
+            throw new PlatformApiDataValidationException("validation.msg.validation.errors.exist", "Validation errors exist.",
+                    dataValidationErrors);
+        }
+    }
+
+    private void validateLoanForBatchUpdateFirstRepaymentDate(final Loan loan, final LocalDate newRepaymentDate,
+            final Long loanProductId) {
+        final Long loanId = loan.getId();
+        if (!Objects.equals(loan.loanProduct().getId(), loanProductId)) {
+            throw batchUpdateFirstRepaymentDateException(
+                    "error.msg.loan.batch.update.first.repayment.date.loan.product.mismatch",
+                    "Loan " + loanId + " does not belong to loan product " + loanProductId + ".", "loanProductId",
+                    loanProductId, loanId, loanProductId, loan.loanProduct().getId());
+        }
+        if (!loan.isApproved() || loan.isDisbursed()) {
+            throw batchUpdateFirstRepaymentDateException(
+                    "error.msg.loan.batch.update.first.repayment.date.loan.status.invalid",
+                    "Loan " + loanId + " status does not allow first repayment date update. Only approved undisbursed loans are allowed.",
+                    "loanIds", loanId, loanId, loan.getStatus().getValue());
+        }
+        if (loan.getLoanRepaymentScheduleInstallmentsSize() > 0) {
+            throw batchUpdateFirstRepaymentDateException(
+                    "error.msg.loan.batch.update.first.repayment.date.repayment.schedule.exists",
+                    "Loan " + loanId + " already has a repayment schedule and cannot be updated.", "loanIds", loanId, loanId);
+        }
+
+        final LocalDate expectedDisbursementDate = loan.getExpectedDisbursementDate();
+        if (expectedDisbursementDate == null) {
+            throw batchUpdateFirstRepaymentDateException(
+                    "error.msg.loan.batch.update.first.repayment.date.disbursement.date.missing",
+                    "Loan " + loanId + " does not have an expected disbursement date.", "loanIds", loanId, loanId);
+        }
+        if (DateUtils.isBefore(newRepaymentDate, expectedDisbursementDate)) {
+            throw batchUpdateFirstRepaymentDateException(
+                    "error.msg.loan.batch.update.first.repayment.date.before.disbursement.date",
+                    "Loan " + loanId + " has an invalid repayment date. The new first repayment date cannot be before the expected disbursement date.",
+                    "newRepaymentDate", newRepaymentDate, loanId, expectedDisbursementDate);
+        }
+
+        final LocalDate minimumFirstRepaymentDate = expectedDisbursementDate
+                .plusDays(loan.loanProduct().getMinimumDaysBetweenDisbursalAndFirstRepayment());
+        if (DateUtils.isBefore(newRepaymentDate, minimumFirstRepaymentDate)) {
+            throw batchUpdateFirstRepaymentDateException(
+                    "error.msg.loan.batch.update.first.repayment.date.minimum.days.violation",
+                    "Loan " + loanId + " has an invalid repayment date. The new first repayment date violates the minimum days between disbursal and first repayment.",
+                    "newRepaymentDate", newRepaymentDate, loanId, minimumFirstRepaymentDate,
+                    loan.loanProduct().getMinimumDaysBetweenDisbursalAndFirstRepayment());
+        }
+        if (loan.getSubmittedOnDate() != null && DateUtils.isAfter(loan.getSubmittedOnDate(), newRepaymentDate)) {
+            throw batchUpdateFirstRepaymentDateException(
+                    "error.msg.loan.batch.update.first.repayment.date.before.submitted.on.date",
+                    "Loan " + loanId + " has an invalid repayment date. The new first repayment date cannot be before the submitted on date.",
+                    "newRepaymentDate", newRepaymentDate, loanId, loan.getSubmittedOnDate());
+        }
+
+        final HolidayDetailDTO holidayDetailDTO = this.loanUtilService.constructHolidayDTO(loan.getOfficeId(), expectedDisbursementDate);
+        if (!holidayDetailDTO.isAllowTransactionsOnHoliday() && HolidayUtil.isHoliday(newRepaymentDate, holidayDetailDTO.getHolidays())) {
+            throw batchUpdateFirstRepaymentDateException(
+                    "error.msg.loan.batch.update.first.repayment.date.on.holiday",
+                    "Loan " + loanId + " has an invalid repayment date. The new first repayment date cannot be on a holiday.",
+                    "newRepaymentDate", newRepaymentDate, loanId);
+        }
+        if (!holidayDetailDTO.isAllowTransactionsOnNonWorkingDay()
+                && !WorkingDaysUtil.isWorkingDay(holidayDetailDTO.getWorkingDays(), newRepaymentDate)) {
+            throw batchUpdateFirstRepaymentDateException(
+                    "error.msg.loan.batch.update.first.repayment.date.on.non.working.day",
+                    "Loan " + loanId + " has an invalid repayment date. The new first repayment date cannot be on a non working day.",
+                    "newRepaymentDate", newRepaymentDate, loanId);
+        }
+    }
+
+    private PlatformApiDataValidationException batchUpdateFirstRepaymentDateException(final String messageCode,
+            final String defaultUserMessage, final String parameterName, final Object value, final Object... userMessageArgs) {
+        return new PlatformApiDataValidationException("validation.msg.validation.errors.exist", "Validation errors exist.",
+                List.of(ApiParameterError.parameterError(messageCode, defaultUserMessage, parameterName, value, userMessageArgs)));
+    }
 }
