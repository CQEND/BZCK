+        if (loanIds == null || loanIds.isEmpty()) {
+            throw new PlatformApiDataValidationException("error.msg.loan.ids.cannot.be.empty", "Loan IDs list cannot be empty", "loanIds");
+        }
+        if (newRepaymentDate == null) {
+            throw new PlatformApiDataValidationException("error.msg.new.repayment.date.cannot.be.null", "New repayment date cannot be null", "newRepaymentDate");
+        }
+        if (loanProductId == null) {
+            throw new PlatformApiDataValidationException("error.msg.loan.product.id.cannot.be.null", "Loan product ID cannot be null", "loanProductId");
+        }
+
+        for (Long loanId : loanIds) {
+            Loan loan = this.loanAssembler.assembleFrom(loanId);
+            
+            if (!loan.getLoanProduct().getId().equals(loanProductId)) {
+                throw new GeneralPlatformDomainRuleException("error.msg.loan.product.mismatch",
+                        "Loan with identifier " + loanId + " does not belong to product " + loanProductId, loanId);
+            }
+            
+            if (!loan.isApproved() || loan.isDisbursed()) {
+                throw new GeneralPlatformDomainRuleException("error.msg.loan.status.not.approved.or.already.disbursed",
+                        "Loan with identifier " + loanId + " must be in 'Approved' status and not disbursed.", loanId);
+            }
+            
+            if (loan.getRepaymentScheduleInstallments() != null && !loan.getRepaymentScheduleInstallments().isEmpty()) {
+                throw new GeneralPlatformDomainRuleException("error.msg.loan.repayment.schedule.already.generated",
+                        "Loan with identifier " + loanId + " already has a repayment schedule generated.", loanId);
+            }
+            
+            loan.setExpectedFirstRepaymentOnDate(newRepaymentDate);
+            saveLoanWithDataIntegrityViolationChecks(loan);
+        }
+    }
