+
+        if (request.getLoanIds() == null || request.getLoanIds().isEmpty()) {
+            throw new IllegalArgumentException("loanIds cannot be null or empty");
+        }
+        if (request.getNewRepaymentDate() == null) {
+            throw new IllegalArgumentException("newRepaymentDate cannot be null");
