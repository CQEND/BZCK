+    public String batchUpdateFirstRepaymentDate(@Parameter(hidden = true) final String apiRequestBodyAsJson) {
+        this.context.authenticatedUser().validateHasEditPermission(RESOURCE_NAME_FOR_PERMISSIONS);
+
+        Gson gson = new GsonBuilder()
+                .registerTypeAdapter(LocalDate.class,
+                        (JsonDeserializer<LocalDate>) (json, typeOfT, context) -> LocalDate.parse(json.getAsString()))
+                .create();
