+
+    @Override
+    @Transactional
+    public void batchUpdateFirstRepaymentDate(List<Long> loanIds, LocalDate newRepaymentDate, Long loanProductId) {
+        List<Long> updatedLoanIds = new ArrayList<>();
+
+        for (Long loanId : loanIds) {
+            Loan loan = loanRepositoryWrapper.findOneWithNotFoundDetection(loanId);
+
+            if (!loan.getStatus().isApproved()) {
+                throw new GeneralPlatformDomainRuleException(
+                        "error.msg.loan.batch.update.first.repayment.date.status.invalid",
+                        "Loan " + loanId + " is not in APPROVED status. Only approved loans can be updated",
+                        loanId);
+            }
+
+            if (loan.isDisbursed()) {
+                throw new GeneralPlatformDomainRuleException(
+                        "error.msg.loan.batch.update.first.repayment.date.already.disbursed",
+                        "Loan " + loanId + " has already been disbursed. Cannot update repayment date after disbursement",
+                        loanId);
+            }
+
+            if (!loan.getLoanProduct().getId().equals(loanProductId)) {
+                throw new GeneralPlatformDomainRuleException(
+                        "error.msg.loan.batch.update.first.repayment.date.product.mismatch",
+                        "Loan " + loanId + " product ID does not match. Expected: " + loanProductId +
+                                ", Actual: " + loan.getLoanProduct().getId(),
+                        loanId);
+            }
+
+            List<LoanRepaymentScheduleInstallment> installments = loan.getRepaymentScheduleInstallments();
+            if (!installments.isEmpty()) {
+                throw new GeneralPlatformDomainRuleException(
+                        "error.msg.loan.batch.update.first.repayment.date.schedule.exists",
+                        "Loan " + loanId + " already has a repayment schedule generated. Cannot update first repayment date",
+                        loanId);
+            }
+
+            if (DateUtils.isBefore(newRepaymentDate, loan.getExpectedDisbursedOnLocalDate())) {
+                throw new GeneralPlatformDomainRuleException(
+                        "error.msg.loan.batch.update.first.repayment.date.before.disbursement",
+                        "New first repayment date " + newRepaymentDate +
+                                " cannot be before expected disbursement date " + loan.getExpectedDisbursedOnLocalDate(),
+                        loanId);
+            }
+
+            loan.setExpectedFirstRepaymentOnDate(newRepaymentDate);
+            saveAndFlushLoanWithDataIntegrityViolationChecks(loan);
+            updatedLoanIds.add(loanId);
+        }
+    }
 }
