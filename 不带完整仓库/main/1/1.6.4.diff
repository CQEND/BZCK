+    @Transactional
+    @Override
+    public org.apache.fineract.portfolio.loanaccount.data.BatchUpdateRepaymentDateResponse batchUpdateFirstRepaymentDate(
+            final List<Long> loanIds, final LocalDate newRepaymentDate, final Long loanProductId) {
+
+        if (loanIds == null || loanIds.isEmpty()) {
+            throw new GeneralPlatformDomainRuleException("error.msg.loan.ids.empty", "Loan IDs list cannot be empty");
+        }
+
+        if (newRepaymentDate == null) {
+            throw new GeneralPlatformDomainRuleException("error.msg.repayment.date.empty", "New repayment date cannot be empty");
+        }
+
+        if (loanProductId == null) {
+            throw new GeneralPlatformDomainRuleException("error.msg.loan.product.id.empty", "Loan product ID cannot be empty");
+        }
+
+        final List<Long> updatedLoanIds = new ArrayList<>();
+
+        for (final Long loanId : loanIds) {
+            final Loan loan = loanAssembler.assembleFrom(loanId);
+
+            if (!loan.getStatus().isApproved()) {
+                throw new GeneralPlatformDomainRuleException("error.msg.loan.status.not.approved",
+                        "Loan " + loanId + " is not in approved status");
+            }
+
+            if (!loan.getRepaymentScheduleInstallments().isEmpty()) {
+                throw new GeneralPlatformDomainRuleException("error.msg.loan.schedule.already.generated",
+                        "Loan " + loanId + " already has repayment schedule generated");
+            }
+
+            if (!Objects.equals(loan.productId(), loanProductId)) {
+                throw new GeneralPlatformDomainRuleException("error.msg.loan.product.mismatch",
+                        "Loan " + loanId + " does not belong to product " + loanProductId);
+            }
+
+            loan.setExpectedFirstRepaymentOnDate(newRepaymentDate);
+            saveAndFlushLoanWithDataIntegrityViolationChecks(loan);
+            updatedLoanIds.add(loanId);
+        }
+
+        return new org.apache.fineract.portfolio.loanaccount.data.BatchUpdateRepaymentDateResponse(updatedLoanIds.size(),
+                updatedLoanIds);
+    }
