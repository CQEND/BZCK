+
+    @Override
+    @Transactional
+    public BatchUpdateRepaymentDateResponse batchUpdateFirstRepaymentDate(List<Long> loanIds, LocalDate newRepaymentDate,
+            Long loanProductId) {
+        List<Long> updatedLoanIds = new ArrayList<>();
+        List<String> errors = new ArrayList<>();
+
+        for (Long loanId : loanIds) {
+            try {
+                Loan loan = this.loanRepository.findById(loanId).orElseThrow(() -> new LoanNotFoundException(loanId));
+
+                if (!loan.getStatus().isApproved()) {
+                    errors.add("Loan ID " + loanId + " is not in approved status. Current status: " + loan.getStatus().getCode());
+                    continue;
+                }
+
+                if (!loan.isNotDisbursed()) {
+                    errors.add("Loan ID " + loanId + " has already been disbursed");
+                    continue;
+                }
+
+                if (loanProductId != null && !loan.getLoanProduct().getId().equals(loanProductId)) {
+                    errors.add("Loan ID " + loanId + " does not belong to the specified loan product ID " + loanProductId);
+                    continue;
+                }
+
+                List<LoanRepaymentScheduleInstallment> installments = loan.getRepaymentScheduleInstallments();
+                if (installments != null && !installments.isEmpty()) {
+                    errors.add("Loan ID " + loanId + " already has a repayment schedule generated");
+                    continue;
+                }
+
+                if (newRepaymentDate == null) {
+                    errors.add("New repayment date cannot be null for loan ID " + loanId);
+                    continue;
+                }
+
+                if (DateUtils.isBefore(newRepaymentDate, DateUtils.getBusinessLocalDate())) {
+                    errors.add("New repayment date for loan ID " + loanId + " cannot be in the past");
+                    continue;
+                }
+
+                loan.setExpectedFirstRepaymentOnDate(newRepaymentDate);
+                this.loanRepository.save(loan);
+                updatedLoanIds.add(loanId);
+            } catch (LoanNotFoundException e) {
+                errors.add("Loan ID " + loanId + " does not exist");
+            }
+        }
+
+        if (!errors.isEmpty()) {
+            throw new PlatformApiDataValidationException("validation.msg.loan.batchUpdateRepaymentDate.validationErrors",
+                    "Some loans failed validation", errors.stream().map(err -> new ApiParameterError(0, err, err)).toList());
+        }
+
+        BatchUpdateRepaymentDateResponse response = new BatchUpdateRepaymentDateResponse();
+        response.setTotalUpdated(updatedLoanIds.size());
+        response.setUpdatedLoanIds(updatedLoanIds);
+        return response;
+    }
 }
