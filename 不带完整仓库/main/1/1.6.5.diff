+            + "Returns 200 OK with totalUpdated count and updatedLoanIds on success.\n"
+            + "Returns 400 Bad Request with validation errors if any loan fails validation.")
+    @ApiResponses({
+            @ApiResponse(responseCode = "200", description = "OK", content = @Content(schema = @Schema(implementation = BatchUpdateRepaymentDateResponse.class))),
+            @ApiResponse(responseCode = "400", description = "Bad Request - Validation errors occurred") })
+    public BatchUpdateRepaymentDateResponse batchUpdateFirstRepaymentDate(
+            @Parameter(hidden = true) final String apiRequestBodyAsJson) {
+        this.context.authenticatedUser().validateHasUpdatePermission(RESOURCE_NAME_FOR_PERMISSIONS);
+
+        final JsonElement parsedCommand = this.fromJsonHelper.parse(apiRequestBodyAsJson);
+
+        final JsonArray loanIdsArray = parsedCommand.getAsJsonArray("loanIds");
+        List<Long> loanIds = new ArrayList<>();
+        for (JsonElement element : loanIdsArray) {
+            loanIds.add(element.getAsLong());
+        }
+
+        Long loanProductId = null;
+        if (parsedCommand.isJsonObject() && parsedCommand.getAsJsonObject().has("loanProductId")) {
+            loanProductId = parsedCommand.getAsJsonObject().get("loanProductId").getAsLong();
+        }
+
+        LocalDate newRepaymentDate = null;
+        if (parsedCommand.isJsonObject() && parsedCommand.getAsJsonObject().has("newRepaymentDate")) {
+            JsonElement dateElement = parsedCommand.getAsJsonObject().get("newRepaymentDate");
+            if (dateElement.isJsonPrimitive()) {
+                String dateFormat = parsedCommand.getAsJsonObject().has("dateFormat")
+                        ? parsedCommand.getAsJsonObject().get("dateFormat").getAsString()
+                        : "yyyy-MM-dd";
+                String locale = parsedCommand.getAsJsonObject().has("locale")
+                        ? parsedCommand.getAsJsonObject().get("locale").getAsString()
+                        : "en";
+                newRepaymentDate = this.fromJsonHelper.extractLocalDateNamed("newRepaymentDate", parsedCommand,
+                        java.util.Set.of("dateFormat", dateFormat, "locale", locale));
+            }
+        }
+
+        return this.loanWritePlatformService.batchUpdateFirstRepaymentDate(loanIds, newRepaymentDate, loanProductId);
+    }
 }
