+def test_irrelevant_meta_is_stripped_from_schema():
+    schema = {
+        'type': 'integer',
+        'readOnly': True,
+        'writeOnly': True,
+        'example': 1,
+    }
+    param = build_parameter_type(name='id', schema=schema, location=OpenApiParameter.QUERY)
+    assert 'readOnly' not in param['schema']
