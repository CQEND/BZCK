+import { resolve } from 'path'
+import type { Test } from 'tap'
+import t from 'tap'
+import type { GlobOptionsWithFileTypesUnset } from '../src/index.js'
+import { glob, globSync } from '../src/index.js'
+
+const alphasort = (a: string, b: string) => a.localeCompare(b, 'en')
+const sort = (paths: string[]) => paths.sort(alphasort)
+
+const check = async (
+  t: Test,
+  pattern: string,
+  options: GlobOptionsWithFileTypesUnset,
+  expect: string[],
+) => {
+  const expected = sort([...expect])
+  t.strictSame(sort(await glob(pattern, options)), expected, 'async')
+  t.strictSame(sort(globSync(pattern, options)), expected, 'sync')
+}
+
+t.test('gitignore:true loads the nearest .gitignore', async t => {
+  const cwd = t.testdir({
+    'proj[1]': {
+      '.gitignore': 'ignored-dir/\n*.log\n',
+      nested: {
+        'debug.log': '',
+        'keep.ts': '',
+        'ignored-dir': {
+          'skip.ts': '',
+        },
+      },
+    },
+  })
+
+  await check(
+    t,
+    '**/*',
+    {
+      cwd: resolve(cwd, 'proj[1]/nested'),
+      gitignore: true,
+      nodir: true,
+      posix: true,
+    },
+    ['keep.ts'],
+  )
+})
+
+t.test('gitignore path merges with ignore', async t => {
+  const cwd = t.testdir({
+    'proj[1]': {
+      '.gitignore': 'vendor/\n*.tmp\n',
+      src: {
+        'drop.js': '',
+        'keep.js': '',
+        'skip.tmp': '',
+        vendor: {
+          'vendored.js': '',
+        },
+      },
+    },
+  })
+
+  await check(
+    t,
+    '**/*',
+    {
+      cwd: resolve(cwd, 'proj[1]/src'),
+      gitignore: '../.gitignore',
+      ignore: 'drop.js',
+      nodir: true,
+      posix: true,
+    },
+    ['keep.js'],
+  )
+})
