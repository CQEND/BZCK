@@ -0,0 +1,74 @@
+import t from 'tap'
+import { resolve } from 'node:path'
+import { writeFileSync, mkdirSync, rmSync } from 'node:fs'
+import { glob, globSync } from '../src/index.js'
+
+const fixtureDir = resolve(__dirname, 'fixtures', 'gitignore-test')
+
+t.before(() => {
+  rmSync(fixtureDir, { recursive: true, force: true })
+  mkdirSync(fixtureDir, { recursive: true })
+  mkdirSync(resolve(fixtureDir, 'node_modules'))
+  mkdirSync(resolve(fixtureDir, 'src'))
+  mkdirSync(resolve(fixtureDir, 'src', 'node_modules'))
+  
+  writeFileSync(resolve(fixtureDir, '.gitignore'), `
+# comment
+node_modules
+/dist
+*.log
+!important.log
+dir/
+  `)
+  
+  writeFileSync(resolve(fixtureDir, 'node_modules', 'a.js'), '')
+  writeFileSync(resolve(fixtureDir, 'src', 'node_modules', 'b.js'), '')
+  writeFileSync(resolve(fixtureDir, 'src', 'c.js'), '')
+  
+  mkdirSync(resolve(fixtureDir, 'dist'))
+  writeFileSync(resolve(fixtureDir, 'dist', 'd.js'), '')
+  
+  writeFileSync(resolve(fixtureDir, 'a.log'), '')
+  writeFileSync(resolve(fixtureDir, 'important.log'), '')
+  
+  mkdirSync(resolve(fixtureDir, 'dir'))
+  writeFileSync(resolve(fixtureDir, 'dir', 'e.js'), '')
+  writeFileSync(resolve(fixtureDir, 'dir.js'), '') // file named dir.js
+})
+
+t.after(() => {
+  rmSync(fixtureDir, { recursive: true, force: true })
+})
+
+t.test('gitignore true finds nearest .gitignore and applies rules', async (t) => {
+  const opts = { cwd: fixtureDir, gitignore: true, posix: true }
+  const res = await glob('**', opts)
+  
+  t.notOk(res.includes('node_modules/a.js'), 'should ignore node_modules')
+  t.notOk(res.includes('src/node_modules/b.js'), 'should ignore nested node_modules')
+  t.ok(res.includes('src/c.js'), 'should include src/c.js')
+  t.notOk(res.includes('dist/d.js'), 'should ignore /dist')
+  t.notOk(res.includes('a.log'), 'should ignore *.log')
+  t.ok(res.includes('important.log'), 'should not ignore !important.log')
+  t.notOk(res.includes('dir/e.js'), 'should ignore dir/ directory')
+  t.ok(res.includes('dir.js'), 'should include dir.js file')
+
+  const resSync = globSync('**', opts)
+  t.same(res.sort(), resSync.sort(), 'sync and async should match')
+})
+
+t.test('gitignore as string uses exact file', async (t) => {
+  const opts = { cwd: resolve(fixtureDir, 'src'), gitignore: resolve(fixtureDir, '.gitignore'), posix: true }
+  const res = await glob('**', opts)
+  
+  t.notOk(res.includes('node_modules/b.js'), 'should ignore nested node_modules when using exact file')
+  t.ok(res.includes('c.js'), 'should include c.js')
+})
+
+t.test('gitignore merges with ignore option', async (t) => {
+  const opts = { cwd: fixtureDir, gitignore: true, ignore: 'src/c.js', posix: true }
+  const res = await glob('**', opts)
+  
+  t.notOk(res.includes('node_modules/a.js'), 'should ignore node_modules from gitignore')
+  t.notOk(res.includes('src/c.js'), 'should ignore src/c.js from ignore option')
+})
