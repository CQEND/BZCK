+/**
+ * Loads .gitignore rules from a file, or finds the nearest .gitignore
+ * file starting from the cwd.
+ */
+export function loadGitignore(
+  gitignore: string | boolean,
+  opts: GlobWalkerOpts,
+  scurry: PathScurry
+): string[] {
+  let file: string | undefined
+  if (typeof gitignore === 'string') {
+    file = resolve(scurry.cwd.fullpath(), gitignore)
+  } else if (gitignore === true) {
+    let p: Path | undefined = scurry.cwd
+    while (p) {
+      try {
+        const fp = p.resolve('.gitignore').fullpath()
+        const content = ((opts as any).fs?.readFileSync || readFileSync)(fp, 'utf8')
+        file = fp
+        break
+      } catch {
+        p = p.parent
+      }
+    }
+  }
+
+  if (!file) return []
+
+  try {
+    const content = ((opts as any).fs?.readFileSync || readFileSync)(file, 'utf8')
+    const rules = content.split(/\r?\n/).filter((line: string) => {
+      line = line.trim()
+      return line && !line.startsWith('#')
+    })
+
+    const baseDir = dirname(file).replace(/\\/g, '/')
+    const results: string[] = []
+
+    for (let rule of rules) {
+      let isNegated = false
+      if (rule.startsWith('!')) {
+        isNegated = true
+        rule = rule.substring(1)
+      }
+      
+      let isDir = false
+      if (rule.endsWith('/')) {
+        isDir = true
+        rule = rule.slice(0, -1)
+      }
+
+      let isAnchored = false
+      if (rule.startsWith('/')) {
+        isAnchored = true
+        rule = rule.substring(1)
+      } else if (rule.includes('/')) {
+        isAnchored = true
+      }
+
+      // Prefix anchored rules with baseDir
+      if (isAnchored) {
+        const prefix = baseDir.endsWith('/') ? baseDir : `${baseDir}/`
+        rule = `${prefix}${rule}`
+      } else {
+        // Not anchored, matches anywhere
+        rule = `**/${rule}`
+      }
+      
+      if (isDir) {
+        rule = `${rule}/**`
+        results.push(isNegated ? `!${rule}` : rule)
+      } else {
+        results.push(isNegated ? `!${rule}` : rule)
+        rule = `${rule}/**`
+        results.push(isNegated ? `!${rule}` : rule)
+      }
+    }
+
+    return results
+  } catch {
+    return []
+  }
+}
