+
+t.test('gitignore with no .gitignore file returns all results', async t => {
+  await setup({
+    'a.txt': '',
+    'b.txt': '',
+  })
+  const syncRes = globSync('**', { cwd: tmpBase, gitignore: true, nodir: true })
