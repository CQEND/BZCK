+import { mkdir, rm, writeFile } from 'node:fs/promises'
+import { resolve } from 'node:path'
+import { fileURLToPath } from 'node:url'
+import t from 'tap'
+import { glob, globSync } from '../dist/esm/index.js'
+
+const __dirname = fileURLToPath(new URL('.', import.meta.url))
+const j = (a: string[]) =>
+  a
+    .map(s => s.replace(/\\/g, '/'))
+    .sort((a, b) => a.localeCompare(b, 'en'))
+
+const tmpBase = resolve(__dirname, 'fixtures', 'gitignore-test')
+
+async function setup(files: Record<string, string>) {
+  await rm(tmpBase, { recursive: true, force: true })
+  await mkdir(tmpBase, { recursive: true })
+  for (const [name, content] of Object.entries(files)) {
+    const fullPath = resolve(tmpBase, name)
+    await mkdir(resolve(fullPath, '..'), { recursive: true })
+    await writeFile(fullPath, content)
+  }
+}
+
+t.teardown(async () => {
+  await rm(tmpBase, { recursive: true, force: true })
+})
+
+t.test('gitignore: true loads nearest .gitignore', async t => {
+  await setup({
+    '.gitignore': 'ignored.txt\nsubdir/\n',
+    'a.txt': '',
+    'ignored.txt': '',
+    'subdir/x.txt': '',
+    'subdir/y.txt': '',
+    'other/b.txt': '',
+  })
+  const syncRes = globSync('**', { cwd: tmpBase, gitignore: true, nodir: true })
+  const asyncRes = await glob('**', { cwd: tmpBase, gitignore: true, nodir: true })
+  t.same(j(syncRes), j(['a.txt', 'other/b.txt']))
+  t.same(j(asyncRes), j(['a.txt', 'other/b.txt']))
+})
+
+t.test('gitignore: string path to gitignore file', async t => {
+  await setup({
+    'custom.gitignore': 'ignored.txt\n',
+    'a.txt': '',
