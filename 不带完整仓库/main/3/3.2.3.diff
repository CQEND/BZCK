+
+export function parseGitignore(content: string): string[] {
+  const patterns: string[] = []
+  for (let line of content.split(/\r?\n/)) {
+    line = line.trim()
+    if (!line || line[0] === '#') continue
+    if (line[0] === '!') continue
+    if (line.endsWith('/')) {
+      const dirPattern = line.slice(0, -1)
+      patterns.push(dirPattern, `${dirPattern}/**`)
+    } else {
+      patterns.push(line)
+    }
+  }
+  return patterns
+}
+
+export function loadGitignoreSync(
+  gitignore: boolean | string,
+  cwd: string,
+): string[] {
+  let giPath: string | undefined
+  if (typeof gitignore === 'string') {
+    giPath = resolve(cwd, gitignore)
+  } else {
+    giPath = findGitignore(cwd)
+    if (!giPath) return []
+  }
+  if (!existsSync(giPath)) return []
+  return parseGitignore(readFileSync(giPath, 'utf8'))
+}
+
+export async function loadGitignore(
+  gitignore: boolean | string,
+  cwd: string,
+): Promise<string[]> {
+  const giPath =
+    typeof gitignore === 'string' ?
+      resolve(cwd, gitignore)
+    : findGitignore(cwd)
+  if (!giPath) return []
+  try {
+    const content = await readFile(giPath, 'utf8')
+    return parseGitignore(content)
+  } catch {
+    return []
+  }
+}
+
+function findGitignore(cwd: string): string | undefined {
+  let dir = resolve(cwd)
+  let prev: string | undefined
+  while (prev !== dir) {
+    const candidate = resolve(dir, '.gitignore')
+    if (existsSync(candidate)) return candidate
+    prev = dir
+    dir = dirname(dir)
+  }
+  return existsSync(resolve(dir, '.gitignore')) ?
+      resolve(dir, '.gitignore')
+    : undefined
+}
