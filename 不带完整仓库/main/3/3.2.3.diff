+    cwd: tmpBase,
+    gitignore: true,
+    ignore: 'also-ignored.txt',
+    nodir: true,
+  })
+  const asyncRes = await glob('**', {
+    cwd: tmpBase,
+    gitignore: true,
+    ignore: 'also-ignored.txt',
+    nodir: true,
