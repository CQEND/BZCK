+  t.notOk(sync.includes('a.bak'), 'explicit ignore rule a.bak filtered')
+  t.ok(sync.includes('a.txt'), 'a.txt retained')
+  t.strictSame(sync, async_, 'sync and async results match')
+  t.end()
+})
+
+t.test('glob: gitignore merges into array-style ignore too', async t => {
+  const cwd = t.testdir({
+    '.gitignore': '*.log\n',
+    'a.log': '',
+    'a.bak': '',
