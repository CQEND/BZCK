+ *
+ * - `<pattern>` — matches the path itself (file or directory)
+ * - `<pattern>/**` — matches anything beneath it
+ *
+ * which is what the `Ignore` class expects so that descendants are also
+ * excluded.
+ */
+export const gitignoreToGlobPatterns = (
+  pattern: string,
+  basePath: string,
+  platform: NodeJS.Platform = defaultPlatform,
+): string[] => {
+  let p = pattern
+
+  // trim trailing whitespace that is not escaped
+  if (/[^\\]\s+$/.test(p)) p = p.replace(/\s+$/, '')
+  if (!p) return []
+
+  // detect and strip trailing slash (directory-only)
+  const dirOnly = p.endsWith('/')
+  if (dirOnly) {
+    p = p.slice(0, -1)
+    if (!p) return []
+  }
+
+  const anchoredAtRoot = p.startsWith('/')
+  if (anchoredAtRoot) p = p.slice(1)
+
+  // decide whether this pattern is anchored to the gitignore directory
+  const hasMiddleSlash = p.includes('/')
+  const anchored = anchoredAtRoot || hasMiddleSlash
