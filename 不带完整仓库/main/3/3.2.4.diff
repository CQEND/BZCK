+import { writeFileSync } from 'fs'
+import { join } from 'path'
+import t from 'tap'
+import type { GlobOptionsWithFileTypesUnset } from '../src/index.js'
+import {
+  gitignoreToGlobPatterns,
+  glob,
+  globSync,
+  loadGitignore,
+} from '../src/index.js'
+
+const sort = <T>(arr: T[]) => [...arr].sort()
+
+t.test('gitignoreToGlobPatterns: unanchored pattern', t => {
+  const pats = gitignoreToGlobPatterns('node_modules', '/proj')
+  // at minimum should include forms matching node_modules at any depth
+  t.ok(pats.includes('node_modules'), 'bare stem included')
+  t.ok(pats.includes('**/node_modules'), 'star-prefixed stem included')
+  t.ok(pats.includes('/proj/node_modules'), 'base-prefixed stem included')
+  t.ok(pats.some(p => p.endsWith('/**')), 'has /** descendant form')
+  t.end()
+})
+
+t.test('gitignoreToGlobPatterns: anchored pattern', t => {
+  const pats = gitignoreToGlobPatterns('/build', '/proj')
+  t.ok(pats.includes('/proj/build'), 'anchored to base')
+  t.ok(pats.includes('/proj/build/**'), 'anchored descendant form')
+  t.notOk(pats.includes('**/build'), 'no anywhere form when anchored')
+  t.end()
+})
+
+t.test('gitignoreToGlobPatterns: middle-slash = anchored', t => {
+  const pats = gitignoreToGlobPatterns('foo/bar', '/proj')
+  t.ok(pats.includes('/proj/foo/bar'), 'middle slash anchors to base')
+  t.ok(pats.includes('/proj/foo/bar/**'))
+  t.end()
+})
+
+t.test('gitignoreToGlobPatterns: dir-only pattern', t => {
+  const pats = gitignoreToGlobPatterns('dist/', '/proj')
+  // pattern should have been stripped of trailing slash but still produce
+  // entries matching the directory and its descendants.
+  t.ok(pats.includes('/proj/dist') || pats.includes('**/dist'))
+  t.ok(pats.some(p => p.endsWith('/dist/**')))
+  t.end()
+})
+
+t.test('gitignoreToGlobPatterns: empty/blank after trimming', t => {
+  t.strictSame(gitignoreToGlobPatterns('   ', '/proj'), [])
+  // escaped leading space is meaningful — not trimmed in the real loader
+  // because only *trailing* unescaped spaces are stripped.
+  t.not(gitignoreToGlobPatterns('a', '/proj').length, 0)
+  t.end()
+})
+
+t.test('loadGitignore: reads a file and produces patterns', t => {
+  const cwd = t.testdir({
+    '.gitignore': [
+      '# a comment',
+      'node_modules',
+      'build/',
+      '*.log',
+      '!/important.log',
+      '',
+      '/dist',
+    ].join('\n'),
+    node_modules: { x: '' },
+    build: { out: '' },
+    dist: { out: '' },
+    a: {
+      'ignore.log': '',
+      'keep.txt': '',
+    },
+  })
+
+  const gi = loadGitignore({ gitignore: true, cwd })
+  t.ok(gi.length > 0, 'produced some patterns')
+  // negations are currently not enforced here, but the patterns themselves
+  // should not start with `!`
+  t.ok(gi.every(p => !p.startsWith('!')), 'no negation patterns present')
+
+  // .log files, dist, build, node_modules covered
+  t.ok(gi.some(p => p.endsWith('/*.log') || p.endsWith('/**/*.log') ||
+      p.includes('*.log')), 'wildcard present')
+
+  t.end()
+})
+
+t.test('loadGitignore: returns [] when no gitignore and not true', t => {
+  const cwd = t.testdir({ a: '' })
+  t.strictSame(loadGitignore({ cwd }), [])
+  t.strictSame(loadGitignore({ gitignore: false, cwd }), [])
+  t.strictSame(loadGitignore({ gitignore: true, cwd }), [])
+  t.end()
+})
+
+t.test('glob: gitignore option prunes matches', async t => {
+  const cwd = t.testdir({
+    '.gitignore': [
+      'ignored.txt',
+      'build/',
+      '*.log',
+    ].join('\n'),
+    'ignored.txt': '',
+    'kept.txt': '',
+    'debug.log': '',
+    build: {
+      out: '',
+      'deep.log': '',
+    },
+    src: {
+      'ignored.txt': '',
+      'main.js': '',
+    },
+  })
+
+  const pattern = '**'
+  const opts: GlobOptionsWithFileTypesUnset = { cwd, posix: true }
+
+  // baseline: without gitignore, all entries show up
+  const baseline = sort(globSync(pattern, opts))
+  t.ok(baseline.includes('ignored.txt'), 'baseline includes ignored.txt')
+  t.ok(baseline.includes('build/out'), 'baseline includes build/out')
+  t.ok(baseline.includes('debug.log'), 'baseline includes debug.log')
+
+  // with gitignore:true, the ignored paths should be absent
+  const sync = sort(globSync(pattern, { ...opts, gitignore: true }))
+  const async_ = sort(await glob(pattern, { ...opts, gitignore: true }))
+
+  t.notOk(sync.includes('ignored.txt'), 'ignored.txt filtered')
+  t.notOk(sync.includes('src/ignored.txt'), 'src/ignored.txt filtered')
+  t.notOk(sync.includes('build'), 'build directory filtered')
+  t.notOk(sync.includes('build/out'), 'build/out filtered')
+  t.notOk(sync.includes('debug.log'), 'debug.log filtered')
+  t.ok(sync.includes('kept.txt'), 'kept.txt retained')
+  t.ok(sync.includes('src/main.js'), 'src/main.js retained')
+
+  t.strictSame(sync, async_, 'sync and async results match')
+  t.end()
+})
+
+t.test('glob: gitignore option accepts a file path', async t => {
+  const cwd = t.testdir({
+    shared: {
+      'my.gitignore': '*.bak\n',
+    },
+    a: '',
+    'a.bak': '',
+    b: '',
+    'b.bak': '',
+  })
+
+  const pattern = '**'
+  const opts: GlobOptionsWithFileTypesUnset = { cwd, posix: true }
+  const giPath = join(cwd, 'shared', 'my.gitignore')
+
+  const sync = sort(globSync(pattern, { ...opts, gitignore: giPath }))
+  const async_ = sort(await glob(pattern, { ...opts, gitignore: giPath }))
+
+  t.notOk(sync.includes('a.bak'), 'a.bak filtered via custom path')
+  t.notOk(sync.includes('b.bak'), 'b.bak filtered via custom path')
+  t.ok(sync.includes('a'), 'a retained')
+  t.ok(sync.includes('b'), 'b retained')
+  t.strictSame(sync, async_, 'sync and async results match')
+  t.end()
+})
+
+t.test('glob: gitignore merges with, but does not overwrite, ignore', async t => {
+  // gitignore excludes *.log, explicit ignore excludes *.bak
+  const cwd = t.testdir({
+    '.gitignore': '*.log\n',
+    'a.log': '',
+    'a.bak': '',
+    'a.txt': '',
+  })
+
+  const pattern = '**'
+  const opts: GlobOptionsWithFileTypesUnset = {
+    cwd,
+    posix: true,
