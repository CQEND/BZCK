+  t.ok(sync.includes('sub/keep'), 'unrelated content retained')
+  t.end()
+})
+
+// ensure that when a `.gitignore` is passed with an absolute path we
+// do not need to look anywhere else, even from a nested cwd.
+t.test('glob: gitignore string path works from nested cwd', async t => {
+  const root = t.testdir({
+    project: {
+      'shared.gitignore': '*.secret\n',
+      nested: {},
+    },
+  })
+  const cwd = join(root, 'project', 'nested')
+  writeFileSync(join(cwd, 'keep.txt'), '')
+  writeFileSync(join(cwd, 'oops.secret'), '')
+
+  const gi = join(root, 'project', 'shared.gitignore')
+  const sync = sort(globSync('**', { cwd, posix: true, gitignore: gi }))
+  t.notOk(sync.includes('oops.secret'), 'secret filtered via explicit path')
+  t.ok(sync.includes('keep.txt'), 'keep.txt retained')
+  t.end()
+})
