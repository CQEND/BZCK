+    gitignorePath = resolve(cwd, gitignore)
+  } else {
+    let dir = resolve(cwd)
+    gitignorePath = ''
+    while (true) {
+      const candidate = resolve(dir, '.gitignore')
+      if (existsSync(candidate)) {
+        gitignorePath = candidate
+        break
+      }
+      const parent = dirname(dir)
+      if (parent === dir) break
