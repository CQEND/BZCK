+  const bashOutput: { [k: string]: string[] } = {}
+
+  for (const pattern of globs) {
+    t.test(`generate fixture ${pattern}`, t => {
+      const opts = [
+        '-O',
+        'globstar',
+        '-O',
+        'extglob',
+        '-O',
+        'nullglob',
+        '-c',
+        `for i in ${pattern}; do echo $i; done`,
