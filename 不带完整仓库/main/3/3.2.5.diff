+    if (trailingSlash) line = line.slice(0, -1)
+    if (line.startsWith('/')) line = line.slice(1)
+    if (!line) continue
+    if (trailingSlash) {
+      patterns.push(`${line}/**`)
+    } else {
+      patterns.push(line)
+      patterns.push(`${line}/**`)
+    }
+  }
