+      })
+  }
+
+  const flatten = (chunks: Buffer[]) =>
+    Buffer.concat(chunks).toString().trim()
+
+  const alphasort = (a: string, b: string) =>
+    a.toLowerCase().localeCompare(b.toLowerCase(), 'en')
+}
