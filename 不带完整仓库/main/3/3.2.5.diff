+import { mkdirSync, writeFileSync, rmSync } from 'node:fs'
+import { join, resolve } from 'node:path'
+import type { Path } from 'path-scurry'
+import t from 'tap'
+import { fileURLToPath } from 'node:url'
+import type { IgnoreLike } from '../dist/esm/index.js'
+import { glob, globSync } from '../dist/esm/index.js'
+import { loadGitignore } from '../dist/esm/ignore.js'
+
+const __dirname = fileURLToPath(new URL('.', import.meta.url))
+const fixtureDir = resolve(__dirname, 'fixtures', 'gitignore-test')
+
+t.before(() => {
+  const dirs = [
+    'src',
+    'src/lib',
+    'dist',
+    'node_modules',
+    'node_modules/pkg',
+    '.hidden',
+    'build',
+    'build/assets',
+  ]
+  for (const d of dirs) {
+    mkdirSync(join(fixtureDir, d), { recursive: true })
+  }
+  const files = [
+    'src/index.ts',
+    'src/lib/util.ts',
+    'dist/bundle.js',
+    'node_modules/pkg/index.js',
+    '.hidden/secret.txt',
+    'build/assets/main.css',
+    'build/index.html',
+    'README.md',
+    '.env',
+  ]
+  for (const f of files) {
+    writeFileSync(join(fixtureDir, f), 'test')
+  }
+  writeFileSync(
+    join(fixtureDir, '.gitignore'),
+    `node_modules/
+dist
+*.js
+.env
+# this is a comment
+/build/
+`,
+  )
+})
+
+t.teardown(() => {
+  rmSync(fixtureDir, { recursive: true, force: true })
+})
+
+t.test('loadGitignore with true finds .gitignore from cwd', t => {
+  const patterns = loadGitignore(true, fixtureDir)
+  t.ok(patterns.length > 0, 'should find patterns')
+  t.ok(
+    patterns.some(p => p.includes('node_modules')),
+    'should include node_modules',
+  )
+  t.ok(
+    patterns.some(p => p.includes('dist')),
+    'should include dist',
+  )
+  t.ok(
+    patterns.some(p => p.includes('build')),
+    'should include build',
+  )
+  t.ok(
+    patterns.some(p => p.includes('.env')),
+    'should include .env',
+  )
+  t.end()
+})
+
+t.test('loadGitignore with string path', t => {
+  const gitignorePath = join(fixtureDir, '.gitignore')
+  const patterns = loadGitignore(gitignorePath, fixtureDir)
+  t.ok(patterns.length > 0, 'should find patterns')
+  t.ok(
+    patterns.some(p => p.includes('node_modules')),
+    'should include node_modules',
+  )
+  t.end()
+})
+
+t.test('loadGitignore with nonexistent path returns empty', t => {
+  const patterns = loadGitignore(
+    '/nonexistent/path/.gitignore',
+    fixtureDir,
+  )
+  t.same(patterns, [], 'should return empty array')
+  t.end()
+})
+
+t.test('loadGitignore with true and no .gitignore returns empty', t => {
+  const noGitignoreDir = resolve(__dirname, 'fixtures')
+  const patterns = loadGitignore(true, noGitignoreDir)
+  t.ok(Array.isArray(patterns), 'should return array')
+  t.end()
+})
+
+t.test('gitignore:true filters results based on .gitignore', async t => {
+  const results = await glob('**', {
+    cwd: fixtureDir,
+    gitignore: true,
+    dot: true,
+  })
+  t.ok(
+    !results.some(r => r.includes('node_modules')),
+    'should not include node_modules',
+  )
+  t.ok(!results.some(r => r.includes('dist')), 'should not include dist')
+  t.ok(!results.some(r => r.includes('.env')), 'should not include .env')
+  t.ok(!results.some(r => r.includes('build')), 'should not include build')
+  t.ok(
+    results.some(r => r.includes('README.md')),
+    'should include README.md',
+  )
+  t.ok(
+    results.some(r => r.includes('src')),
+    'should include src',
+  )
+})
+
+t.test('gitignore:true sync filters results based on .gitignore', t => {
+  const results = globSync('**', {
+    cwd: fixtureDir,
+    gitignore: true,
+    dot: true,
+  })
+  t.ok(
+    !results.some(r => r.includes('node_modules')),
+    'should not include node_modules',
+  )
+  t.ok(!results.some(r => r.includes('dist')), 'should not include dist')
+  t.ok(!results.some(r => r.includes('.env')), 'should not include .env')
+  t.ok(!results.some(r => r.includes('build')), 'should not include build')
+  t.ok(
+    results.some(r => r.includes('README.md')),
+    'should include README.md',
+  )
+  t.end()
+})
+
+t.test('gitignore with string path', async t => {
+  const gitignorePath = join(fixtureDir, '.gitignore')
+  const results = await glob('**', {
+    cwd: fixtureDir,
+    gitignore: gitignorePath,
+    dot: true,
+  })
+  t.ok(
+    !results.some(r => r.includes('node_modules')),
+    'should not include node_modules',
+  )
+  t.ok(!results.some(r => r.includes('dist')), 'should not include dist')
+})
+
+t.test(
+  'gitignore merges with ignore option without overriding',
+  async t => {
+    const resultsWithoutIgnore = await glob('**', {
+      cwd: fixtureDir,
+      gitignore: true,
+      dot: true,
+    })
+    const resultsWithIgnore = await glob('**', {
+      cwd: fixtureDir,
+      gitignore: true,
+      ignore: 'src/**',
+      dot: true,
+    })
+    t.ok(
+      resultsWithoutIgnore.some(r => r.includes('src')),
+      'without ignore, src should be present',
+    )
+    t.ok(
+      !resultsWithIgnore.some(r => r.includes('src')),
+      'with ignore, src should be excluded',
+    )
+    t.ok(
+      !resultsWithIgnore.some(r => r.includes('node_modules')),
+      'gitignore rules still apply',
+    )
+  },
+)
+
+t.test('gitignore with ignore array merges both', async t => {
+  const results = await glob('**', {
+    cwd: fixtureDir,
+    gitignore: true,
+    ignore: ['src/**', 'README.md'],
+    dot: true,
+  })
+  t.ok(
+    !results.some(r => r.includes('src')),
+    'should exclude src from ignore option',
+  )
+  t.ok(
+    !results.some(r => r.includes('README.md')),
+    'should exclude README.md from ignore option',
+  )
+  t.ok(
+    !results.some(r => r.includes('node_modules')),
+    'should still exclude node_modules from gitignore',
+  )
+})
+
+t.test('gitignore:false does not load .gitignore', async t => {
+  const results = await glob('**', {
+    cwd: fixtureDir,
+    dot: true,
+  })
+  t.ok(
+    results.some(r => r.includes('node_modules')),
+    'without gitignore, node_modules should be present',
+  )
+  t.ok(
+    results.some(r => r.includes('dist')),
+    'without gitignore, dist should be present',
+  )
+})
+
+t.test(
+  'dir/ pattern in .gitignore matches directory and children',
+  async t => {
+    const results = await glob('**', {
+      cwd: fixtureDir,
+      gitignore: true,
+      dot: true,
+    })
+    t.ok(
+      !results.some(r => r.includes('build')),
+      'build/ pattern should exclude build dir and its contents',
+    )
+    t.ok(
+      !results.some(r => r.includes('node_modules')),
+      'node_modules/ pattern should exclude dir and contents',
+    )
+  },
+)
+
+t.test('glob pattern in .gitignore like *.js', async t => {
+  const results = await glob('**', {
+    cwd: fixtureDir,
+    gitignore: true,
+    dot: true,
+  })
+  t.ok(
+    !results.some(r => r.endsWith('.js')),
+    '*.js pattern should exclude js files',
+  )
+  t.ok(
+    results.some(r => r.endsWith('.ts')),
+    'ts files should still be present',
+  )
+  t.ok(
+    results.some(r => r.endsWith('.md')),
+    'md files should still be present',
+  )
+})
+
+t.test('gitignore merges with IgnoreLike object', async t => {
+  const customIgnore: IgnoreLike = {
+    ignored: (p: Path) => p.name === 'README.md' || p.name === 'src',
+    childrenIgnored: (p: Path) => p.name === 'src',
+  }
+  const results = await glob('**', {
+    cwd: fixtureDir,
+    gitignore: true,
+    ignore: customIgnore,
+    dot: true,
+  })
+  t.ok(
+    !results.some(r => r.includes('node_modules')),
+    'gitignore rules should apply',
+  )
+  t.ok(
+    !results.some(r => r.endsWith('README.md')),
+    'custom IgnoreLike ignored should apply',
+  )
+  t.ok(
+    !results.some(r => r.includes('src')),
+    'custom IgnoreLike should exclude src entirely',
+  )
+})
+
+t.test('gitignore with IgnoreLike object sync', t => {
+  const customIgnore: IgnoreLike = {
+    ignored: (p: Path) => p.name === 'README.md',
+  }
+  const results = globSync('**', {
+    cwd: fixtureDir,
+    gitignore: true,
+    ignore: customIgnore,
+    dot: true,
+  })
+  t.ok(
+    !results.some(r => r.includes('node_modules')),
+    'gitignore rules should apply',
+  )
+  t.ok(
+    !results.some(r => r.endsWith('README.md')),
+    'custom IgnoreLike should apply',
+  )
+  t.end()
+})
+
+t.test('parseGitignorePatterns edge cases', async t => {
+  const edgeCaseDir = resolve(__dirname, 'fixtures', 'gitignore-edge')
+  mkdirSync(edgeCaseDir, { recursive: true })
+  writeFileSync(join(edgeCaseDir, 'a.txt'), 'test')
+  writeFileSync(join(edgeCaseDir, 'b.txt'), 'test')
+  mkdirSync(join(edgeCaseDir, 'logs'), { recursive: true })
+  writeFileSync(join(edgeCaseDir, 'logs/debug.log'), 'test')
+  mkdirSync(join(edgeCaseDir, 'important'), { recursive: true })
+  writeFileSync(join(edgeCaseDir, 'important/keep.log'), 'test')
+  writeFileSync(
+    join(edgeCaseDir, '.gitignore'),
+    `# comment line
+
+*.log
+!important/
+/logs/
+`,
+  )
+
+  const results = await glob('**', {
+    cwd: edgeCaseDir,
+    gitignore: true,
+    dot: true,
+  })
+  t.ok(
+    results.some(r => r.includes('a.txt')),
+    'a.txt should be present',
+  )
+  t.ok(
+    results.some(r => r.includes('b.txt')),
+    'b.txt should be present',
+  )
+  t.ok(!results.some(r => r.includes('logs')), 'logs/ should be excluded')
+  t.ok(
+    results.some(r => r.includes('important')),
+    'important/ negation should keep it',
+  )
+
+  rmSync(edgeCaseDir, { recursive: true, force: true })
+})
