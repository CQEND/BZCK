+  absolute?: boolean
+  cwd: string
+  root?: string
+  dot: boolean
+  dotRelative: boolean
+  follow: boolean
+  ignore?: string | string[] | IgnoreLike
+  gitignore?: boolean | string
+  magicalBraces: boolean
+  mark?: boolean
+  matchBase: boolean
+  maxDepth: number
+  nobrace: boolean
+  nocase: boolean
+  nodir: boolean
+  noext: boolean
+  noglobstar: boolean
+  pattern: string[]
