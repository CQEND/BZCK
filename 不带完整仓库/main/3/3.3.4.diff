+import { Minimatch } from 'minimatch'
+import type { GlobOptions } from './glob.js'
+
+const stripEscapes = (pattern: string) =>
+  pattern.replace(/\\(.)/g, '$1')
+
+/**
+ * Return true if the patterns provided contain any magic glob characters,
+ * given the options provided.
+ *
+ * Brace expansion is not considered "magic" unless the `magicalBraces` option
+ * is set, as brace expansion just turns one string into an array of strings.
+ * So a pattern like `'x{a,b}y'` would return `false`, because `'xay'` and
+ * `'xby'` both do not contain any magic glob characters, and it's treated the
+ * same as if you had called it on `['xay', 'xby']`. When `magicalBraces:true`
+ * is in the options, brace expansion _is_ treated as a pattern having magic.
+ *
+ * Escaped characters (preceded by a `\`) are not treated as magic, even if the
+ * escaped character would otherwise be a glob magic character such as `*`, `?`,
+ * `[`, or `{`.
+ */
+export const hasMagic = (
+  pattern: string | string[],
+  options: GlobOptions = {},
+): boolean => {
+  for (const p of Array.isArray(pattern) ? pattern : [pattern]) {
+    if (new Minimatch(stripEscapes(p), options).hasMagic()) return true
+  }
+  return false
+}
diff --git a/test/has-magic.ts b/test/has-magic.ts
index 6e7ea01..1b96588 100644
--- a/test/has-magic.ts
+++ b/test/has-magic.ts
@@ -38,3 +38,19 @@ t.test('detect magic in glob patterns', async t => {
     'magical braces not magic in {a,b} nobrace:true',
   )
 })
+
+t.test('escaped magic characters are not magic', async t => {
+  t.notOk(glob.hasMagic('\\{a,b\\}'), 'no magic in \\{a,b\\}')
+  t.notOk(
+    glob.hasMagic('\\{a,b\\}', { magicalBraces: true }),
+    'no magic in \\{a,b\\} with magicalBraces',
+  )
+  t.ok(glob.hasMagic('{a,b}'), 'magic in {a,b} with magicalBraces')
+  t.notOk(glob.hasMagic('foo\\*bar'), 'no magic in foo\\*bar')
+  t.notOk(glob.hasMagic('foo\\[bar\\]'), 'no magic in foo\\[bar\\]')
+  t.notOk(glob.hasMagic('foo\\?bar'), 'no magic in foo\\?bar')
+  t.ok(glob.hasMagic('foo*bar'), 'magic in foo*bar')
+  t.ok(glob.hasMagic('foo[abc]bar'), 'magic in foo[abc]bar')
+  t.ok(glob.hasMagic('foo?bar'), 'magic in foo?bar')
+  t.notOk(glob.hasMagic('\\\\{a,b}'), 'no magic in \\\\{a,b} (escaped backslash, then braces)')
+})
