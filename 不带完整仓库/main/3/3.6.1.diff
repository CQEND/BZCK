  * An object that can perform glob pattern traversals.
  */
 export class Glob<Opts extends GlobOptions> implements GlobOptions {
+  /**
+   * Escape regular expression syntax in a literal string.
+   */
+  static escapeRegExp(str: string): string {
+    return str.replace(/[\\^$.*+?()[\]{}|]/g, '\\$&')
+  }
+
+  /**
+   * Convert a glob pattern into a JavaScript `RegExp`.
+   */
+  static toRegExp(
+    pattern: string,
+    options: GlobToRegExpOptions = {},
+  ): RegExp {
+    const platform = options.platform || defaultPlatform
+    const windowsPathsNoEscape =
+      !!options.windowsPathsNoEscape ||
+      options.allowWindowsEscape === false
+
+    if (options.matchBase && options.noglobstar) {
+      throw new TypeError('base matching requires globstar')
+    }
+
+    const nocase =
+      options.nocase ??
+      (platform === 'darwin' || platform === 'win32')
+
+    const mm = new Minimatch(
+      windowsPathsNoEscape ? pattern.replace(/\\/g, '/') : pattern,
+      {
+        braceExpandMax: 10_000,
+        ...options,
+        nocase,
+        nocomment: true,
+        nonegate: true,
+        optimizationLevel: 2,
+        platform,
+        windowsPathsNoEscape,
+      },
+    )
+    const re = mm.makeRe()
+    if (!re) {
+      throw new TypeError(`invalid glob pattern: ${pattern}`)
+    }
+    if (options.fullMatch !== false) {
+      return re
+    }
+    return new RegExp(
+      re.source.replace(/^\^/, '').replace(/\$$/, ''),
+      re.flags,
+    )
+  }
+
   absolute?: boolean
   cwd: string
   root?: string
