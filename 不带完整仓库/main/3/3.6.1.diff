+import { Minimatch } from 'minimatch'
+import t from 'tap'
+import { Glob, escape, glob, hasMagic, unescape } from '../dist/esm/index.js'
+import { bashResults } from './bash-results.js'
+
+for (const pattern of Object.keys(bashResults)) {
+  t.notOk(hasMagic(escape(pattern)), `escape(${pattern})`)
+  const pp = escape(pattern)
+  const pw = escape(pattern, {
+    windowsPathsNoEscape: true,
+  })
+  t.notOk(
+    hasMagic(pp, { platform: 'linux' }),
+    'no magic after posix escape',
+  )
+  t.notOk(
+    hasMagic(pw, { platform: 'win32', windowsPathsNoEscape: true }),
+    'no magic after windows escape',
+  )
+  const up = unescape(pp)
+  const uw = unescape(pw, { windowsPathsNoEscape: true })
+  t.equal(up, pattern, 'unescaped posix pattern returned')
+  t.equal(uw, pattern, 'unescaped windows pattern returned')
+}
+
+t.test('escapeRegExp escapes regex syntax literally', async t => {
+  const escaped = glob.escapeRegExp('a+b?.[jt]s')
+  t.equal(escaped, 'a\\+b\\?\\.\\[jt\\]s')
+  const re = new RegExp(escaped)
+  t.match('a+b?.[jt]s', re)
+  t.notMatch('abx.js', re)
+  t.equal(escaped, Glob.escapeRegExp('a+b?.[jt]s'))
+})
+
+t.test('toRegExp matches the same paths as minimatch by default', async t => {
+  const cases = [
+    {
+      name: 'wildcards',
+      pattern: '*.js',
+      options: {},
+      paths: ['foo.js', 'foo.ts', 'src/foo.js', '.foo.js'],
+    },
+    {
+      name: 'braces',
+      pattern: 'src/*.{js,ts}',
+      options: {},
+      paths: ['src/a.js', 'src/a.ts', 'src/a.jsx', 'src/a/b.js'],
+    },
+    {
+      name: 'character classes',
+      pattern: 'file-[[:digit:]][ab].js',
+      options: {},
+      paths: ['file-1a.js', 'file-2b.js', 'file-aa.js', 'dir/file-1a.js'],
+    },
+    {
+      name: 'windows paths no escape',
+      pattern: 'src\\*.js',
+      options: { platform: 'win32' as const, windowsPathsNoEscape: true },
+      paths: ['src/foo.js', 'src\\foo.js', 'src/bar.ts'],
+    },
+    {
+      name: 'nocase',
+      pattern: 'README.md',
+      options: { nocase: true },
+      paths: ['README.md', 'readme.md', 'docs/README.md'],
+    },
+  ]
+
+  for (const { name, pattern, options, paths } of cases) {
+    const re = glob.toRegExp(pattern, options)
+    const mm = new Minimatch(pattern, {
+      ...options,
+      nocomment: true,
+      nonegate: true,
+      optimizationLevel: 2,
+    })
+
+    for (const path of paths) {
+      t.equal(
+        re.test(path),
+        mm.match(path),
+        `${name}: ${pattern} => ${path}`,
+      )
+    }
+  }
+
+  t.ok(glob.toRegExp('*.js').test('foo.js'))
+  t.notOk(glob.toRegExp('*.js').test('src/foo.js'))
+})
+
+t.test('toRegExp can search for path fragments with fullMatch:false', async t => {
+  const re = glob.toRegExp('*.js', { fullMatch: false })
+  t.match('prefix foo.js suffix', re)
+  t.notMatch('prefix foo.ts suffix', re)
+})
