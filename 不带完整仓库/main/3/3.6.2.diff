diff --git a/test/to-regexp.ts b/test/to-regexp.ts
new file mode 100644
index 0000000..fe29a67
--- /dev/null
+++ b/test/to-regexp.ts
@@ -0,0 +1,37 @@
+import t from 'tap'
+import { glob, toRegExp, escapeRegExp } from '../src/index.js'
+import { Minimatch } from 'minimatch'
+
+t.test('escapeRegExp', async t => {
+  t.equal(escapeRegExp('*.js'), '\\*\\.js')
+  t.equal(escapeRegExp('foo/bar'), 'foo\\/bar')
+  t.equal(escapeRegExp('{}[]()^$.|*+?\\-'), '\\{\\}\\[\\]\\(\\)\\^\\$\\.\\|\\*\\+\\?\\\\\\-')
+})
+
+t.test('toRegExp', async t => {
+  t.ok(toRegExp('*.js').test('foo.js'), 'matches relative path by default')
+  t.ok(toRegExp('*.js').test('bar/foo.js'), 'matches relative path inside absolute path')
+  t.notOk(toRegExp('*.js').test('foo.json'), 'does not match if extension differs')
+  
+  t.ok(toRegExp('*.js', { fullMatch: true }).test('foo.js'), 'fullMatch matches full string')
+  t.notOk(toRegExp('*.js', { fullMatch: true }).test('bar/foo.js'), 'fullMatch anchors to start')
+
+  // Check that it's consistent with minimatch
+  const mm = new Minimatch('*.js')
+  t.equal(toRegExp('*.js', { fullMatch: true }).test('foo.js'), mm.match('foo.js'))
+  t.equal(toRegExp('*.js', { fullMatch: true }).test('bar/foo.js'), mm.match('bar/foo.js'))
+
+  // Check windows paths and nocase
+  t.ok(toRegExp('*.JS', { nocase: true }).test('foo.js'), 'nocase works')
+  t.ok(toRegExp('foo\\\\*.js', { windowsPathsNoEscape: true }).test('foo/bar.js'), 'windowsPathsNoEscape works')
+
+  // Check wildcards, braces, character classes
+  t.ok(toRegExp('a/{b,c}/*.js').test('a/b/foo.js'), 'brace expansion works')
+  t.ok(toRegExp('a/[b-d]/*.js').test('a/c/foo.js'), 'character class works')
+  t.notOk(toRegExp('a/[b-d]/*.js').test('a/e/foo.js'), 'character class negative match')
+})
+
+t.test('exported on glob object', async t => {
+  t.type(glob.toRegExp, 'function')
+  t.type(glob.escapeRegExp, 'function')
+})
