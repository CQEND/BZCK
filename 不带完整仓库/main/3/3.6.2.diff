+/**
+ * Options for the {@link toRegExp} function.
+ */
+export type ToRegExpOptions = GlobOptions & {
+  /**
+   * By default, the generated RegExp is not anchored to the start of the string
+   * so it can match relative paths within absolute paths.
+   * Set this to `true` to keep the `^` anchor, matching the full string.
+   */
+  fullMatch?: boolean
+}
+
+/**
+ * Escape regular expression special characters in a string.
+ */
+export function escapeRegExp(str: string): string {
+  return str.replace(/[-[\]{}()*+?.,\\^$|#\s]/g, '\\$&')
+}
+
+/**
+ * Convert a glob pattern to a regular expression.
+ */
+export function toRegExp(
+  pattern: string,
+  options: ToRegExpOptions = {}
+): RegExp {
+  const mm = new Minimatch(pattern, options as any)
+  const re = mm.makeRe()
+  if (!re) {
+    return /(?!)/
+  }
+  let source = re.source
+  if (!options.fullMatch) {
+    if (source.startsWith('^')) {
+      source = source.slice(1)
+    }
+  }
+  return new RegExp(source, re.flags)
+}
+
