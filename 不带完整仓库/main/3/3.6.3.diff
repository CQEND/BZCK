+import t from 'tap'
+import { glob } from '../src/index.js'
+import { minimatch } from 'minimatch'
+
+t.test('escapeRegExp escapes regex special characters', t => {
+  t.equal(glob.escapeRegExp('a.b'), 'a\\.b')
+  t.equal(glob.escapeRegExp('a*b'), 'a\\*b')
+  t.equal(glob.escapeRegExp('a+b'), 'a\\+b')
+  t.equal(glob.escapeRegExp('a?b'), 'a\\?b')
+  t.equal(glob.escapeRegExp('a^b'), 'a\\^b')
+  t.equal(glob.escapeRegExp('a$b'), 'a\\$b')
+  t.equal(glob.escapeRegExp('a{b'), 'a\\{b')
+  t.equal(glob.escapeRegExp('a}b'), 'a\\}b')
+  t.equal(glob.escapeRegExp('a(b'), 'a\\(b')
+  t.equal(glob.escapeRegExp('a)b'), 'a\\)b')
+  t.equal(glob.escapeRegExp('a[b'), 'a\\[b')
+  t.equal(glob.escapeRegExp('a]b'), 'a\\]b')
+  t.equal(glob.escapeRegExp('a|b'), 'a\\|b')
+  t.equal(glob.escapeRegExp('a\\b'), 'a\\\\b')
+  t.equal(glob.escapeRegExp('a/b'), 'a\\/b')
+  t.equal(glob.escapeRegExp(''), '')
+  t.equal(glob.escapeRegExp('abc'), 'abc')
+  t.end()
+})
+
+t.test('escapeRegExp is distinct from escape', t => {
+  t.equal(glob.escape('*.js'), '\\*.js')
+  t.equal(glob.escapeRegExp('*.js'), '\\*\\.js')
+  t.equal(glob.escape('a?b'), 'a\\?b')
+  t.equal(glob.escapeRegExp('a?b'), 'a\\?b')
+  t.end()
+})
+
+t.test('toRegExp basic matching', t => {
+  const re = glob.toRegExp('*.js') as RegExp
+  t.ok(re, 'returns a regexp')
+  t.ok(re.test('foo.js'), 'matches foo.js')
+  t.ok(re.test('bar.js'), 'matches bar.js')
+  t.notOk(re.test('foo.txt'), 'does not match foo.txt')
+  t.ok(re.test('path/to/foo.js'), 'matches path/to/foo.js')
+  t.end()
+})
+
+t.test('toRegExp with fullMatch option', t => {
+  const re = glob.toRegExp('*.js', { fullMatch: true }) as RegExp
+  t.ok(re, 'returns a regexp')
+  t.ok(re.test('foo.js'), 'matches foo.js')
+  t.notOk(re.test('foo.txt'), 'does not match foo.txt')
+  t.notOk(re.test('path/to/foo.js'), 'does not match path/to/foo.js with fullMatch')
+  t.end()
+})
+
+t.test('toRegExp does not match across path segments', t => {
+  const re = glob.toRegExp('foo') as RegExp
+  t.ok(re, 'returns a regexp')
+  t.ok(re.test('foo'), 'matches foo')
+  t.ok(re.test('dir/foo'), 'matches dir/foo')
+  t.notOk(re.test('food'), 'does not match food')
+  t.notOk(re.test('foobar'), 'does not match foobar')
+  t.end()
+})
+
+t.test('toRegExp with wildcards', t => {
+  const re = glob.toRegExp('a/*/c') as RegExp
+  t.ok(re, 'returns a regexp')
+  t.ok(re.test('a/b/c'), 'matches a/b/c')
+  t.notOk(re.test('a/b/d'), 'does not match a/b/d')
+  t.ok(re.test('x/a/b/c'), 'matches x/a/b/c')
+  t.end()
+})
+
+t.test('toRegExp with character classes', t => {
+  const re = glob.toRegExp('[abc].js') as RegExp
+  t.ok(re, 'returns a regexp')
+  t.ok(re.test('a.js'), 'matches a.js')
+  t.ok(re.test('b.js'), 'matches b.js')
+  t.ok(re.test('c.js'), 'matches c.js')
+  t.notOk(re.test('d.js'), 'does not match d.js')
+  t.notOk(re.test('A.js'), 'does not match A.js (case sensitive)')
+  t.end()
+})
+
+t.test('toRegExp with nocase option', t => {
+  const re = glob.toRegExp('foo.js', { nocase: true }) as RegExp
+  t.ok(re, 'returns a regexp')
+  t.ok(re.test('foo.js'), 'matches foo.js')
+  t.ok(re.test('FOO.JS'), 'matches FOO.JS')
+  t.ok(re.test('Foo.Js'), 'matches Foo.Js')
+  t.end()
+})
+
+t.test('toRegExp with brace expansion', t => {
+  const re = glob.toRegExp('{foo,bar}.js') as RegExp
+  t.ok(re, 'returns a regexp')
+  t.ok(re.test('foo.js'), 'matches foo.js')
+  t.ok(re.test('bar.js'), 'matches bar.js')
+  t.notOk(re.test('baz.js'), 'does not match baz.js')
+  t.end()
+})
+
+t.test('toRegExp with nobrace option', t => {
+  const re = glob.toRegExp('{foo,bar}.js', { nobrace: true }) as RegExp
+  t.ok(re, 'returns a regexp')
+  t.ok(re.test('{foo,bar}.js'), 'matches literal {foo,bar}.js')
+  t.notOk(re.test('foo.js'), 'does not match foo.js (nobrace)')
+  t.end()
+})
+
+t.test('toRegExp with globstar', t => {
+  const re = glob.toRegExp('a/**/b') as RegExp
+  t.ok(re, 'returns a regexp')
+  t.ok(re.test('a/b'), 'matches a/b')
+  t.ok(re.test('a/x/b'), 'matches a/x/b')
+  t.ok(re.test('a/x/y/b'), 'matches a/x/y/b')
+  t.notOk(re.test('a/c'), 'does not match a/c')
+  t.end()
+})
+
+t.test('toRegExp with extglob', t => {
+  const re = glob.toRegExp('+(a|b).js') as RegExp
+  t.ok(re, 'returns a regexp')
+  t.ok(re.test('a.js'), 'matches a.js')
+  t.ok(re.test('b.js'), 'matches b.js')
+  t.ok(re.test('ab.js'), 'matches ab.js')
+  t.notOk(re.test('c.js'), 'does not match c.js')
+  t.end()
+})
+
+t.test('toRegExp empty/invalid patterns', t => {
+  t.equal(glob.toRegExp(''), false, 'empty string returns false')
+  t.end()
+})
+
+t.test('toRegExp matches minimatch behavior', t => {
+  const patterns: [string, string[], string[]][] = [
+    ['*.js', ['foo.js', 'bar.js', 'foo.txt', 'dir/foo.js', 'dir/sub/foo.js'], []],
+    ['a/b/*', ['a/b/x', 'a/b/y', 'a/c/x', 'x/a/b/y'], []],
+    ['[abc].txt', ['a.txt', 'b.txt', 'c.txt', 'd.txt', 'dir/a.txt'], []],
+    ['+(a|b).js', ['a.js', 'b.js', 'ab.js', 'c.js', 'dir/a.js'], []],
+    ['{a,b}.js', ['a.js', 'b.js', 'c.js', 'dir/a.js'], []],
+    ['a/**/b', ['a/b', 'a/x/b', 'a/x/y/b', 'a/c', 'x/a/b'], []],
+    ['?.*', ['a.js', 'ab.js', '.js', 'dir/a.js'], []],
+    ['[a-z].js', ['a.js', 'z.js', 'A.js', '0.js', 'dir/a.js'], []],
+    ['[!a].js', ['a.js', 'b.js', 'z.js', 'dir/b.js'], []],
+    ['file.{js,ts}', ['file.js', 'file.ts', 'file.css', 'dir/file.js'], []],
+  ]
+
+  for (const [pattern, testPaths] of patterns) {
+    const mmFn = minimatch.filter(pattern, { nonegate: true, nocomment: true })
+    const re = glob.toRegExp(pattern) as RegExp
+
+    for (const p of testPaths) {
+      const mmResult = mmFn(p)
+      const reResult = re.test(p)
+      t.equal(
+        reResult,
+        mmResult,
+        `toRegExp('${pattern}').test('${p}') matches minimatch`,
+      )
+    }
+  }
+
+  t.end()
+})
