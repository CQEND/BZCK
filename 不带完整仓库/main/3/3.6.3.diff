   }
+
+  /**
+   * Convert a glob pattern into a `RegExp`.
+   *
+   * Unlike the raw `minimatch.makeRe()` result, the returned `RegExp`
+   * is _not_ anchored to the start of the string by default, so it
+   * may be used with tools like `sed`, `Array.filter()`, or embedded
+   * into larger regular expressions.
+   *
+   * Use the `fullMatch: true` option to anchor the pattern to both
+   * ends of the tested string (equivalent to `minimatch.makeRe()`).
+   *
+   * e.g. `toRegExp('*.js')` will match `foo.js` but not `bar/foo.js`.
+   *
+   * @example
+   * ```ts
+   * const re = Glob.toRegExp('*.js')
+   * re.test('foo.js') // true
+   * re.test('src/foo.js') // false - does not cross path segments
+   *
+   * const full = Glob.toRegExp('**\/foo.js', { fullMatch: true })
+   * full.test('src/foo.js') // true
+   * ```
+   */
+  static toRegExp(
+    pattern: string,
+    options: GlobToRegExpOptions = {},
+  ): RegExp | false {
+    const mm: MinimatchOptions = {
+      nocase: options.nocase,
+      windowsPathsNoEscape: options.windowsPathsNoEscape,
+      nobrace: options.nobrace,
+      noglobstar: options.noglobstar,
+      noext: options.noext,
+      dot: options.dot,
+      platform: options.platform,
+      nocomment: true,
+      nonegate: true,
+    }
+    const mmRe = makeRe(pattern, mm)
+    if (!mmRe) return mmRe
+    const source = mmRe.source
+    const flags = mmRe.flags
+    if (options.fullMatch) {
+      return new RegExp(source, flags)
+    }
+    let body = source
+    if (body.startsWith('^')) body = body.slice(1)
+    if (body.endsWith('$')) body = body.slice(0, -1)
+    const anchored = `(?:^|\\/)${body}`
+    return new RegExp(anchored, flags)
+  }
+
+  /**
+   * Escape a string so that it matches literally when used inside a
+   * `RegExp`. This escapes _all_ regular-expression metacharacters,
+   * unlike the `escape` helper (which escapes only glob metacharacters.
+   *
+   * @example
+   * ```ts
+   * const re = new RegExp('^' + Glob.escapeRegExp('a.b[c]') + '$')
+   * re.test('a.b[c]') // true
+   * re.test('aXb[c]') // false - '.' is escaped
+   * ```
+   */
+  static escapeRegExp(str: string): string {
+    return str.replace(/[\\^$.*+?()[\]{}|/]/g, '\\$&')
+  }
 }
