+/**
+ * Options for the {@link Glob.toRegExp} static method.
+ */
+export interface GlobToRegExpOptions {
+  /**
+   * Perform a case-insensitive match.
+   */
+  nocase?: boolean
+
+  /**
+   * Treat `\\` as a path separator only, and _never_ as an escape
+   * character. All `\\` characters are replaced with `/` in the pattern.
+   */
+  windowsPathsNoEscape?: boolean
+
+  /**
+   * Do not expand `{a,b}` and `{1..3}` brace sets.
+   */
+  nobrace?: boolean
+
+  /**
+   * Do not match against `**` globstar patterns; treat `**` as a normal `*`.
+   */
+  noglobstar?: boolean
+
+  /**
+   * Do not expand extglob patterns like `+(a|b)`.
+   */
+  noext?: boolean
+
+  /**
+   * Allow patterns to match entries that begin with a `.` without
+   * requiring an explicit leading `.` in the pattern.
+   */
+  dot?: boolean
+
+  /**
+   * If set to `true`, the returned `RegExp` will match the _entire_
+   * tested string (anchored with `^` and `$`). Defaults to `false`,
+   * so the returned `RegExp` may be used with tools like `sed`
+   * or embedded in other `RegExp` patterns.
+   *
+   * When `false`, the pattern still anchors to path boundaries, so
+   * e.g. `toRegExp('*.js')` will match `foo.js` but not `bar/foo.js`.
+   */
+  fullMatch?: boolean
+
+  /**
+   * Operating system platform. Used to determine default case
+   * sensitivity and path separator handling.
+   */
+  platform?: NodeJS.Platform
+}
