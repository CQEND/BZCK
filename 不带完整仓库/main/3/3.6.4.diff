diff --git a/test/to-regexp.ts b/test/to-regexp.ts
new file mode 100644
index 0000000..826c488
--- /dev/null
+++ b/test/to-regexp.ts
@@ -0,0 +1,119 @@
+import t from 'tap'
+import { minimatch } from 'minimatch'
+import { Glob, glob } from '../dist/esm/index.js'
+
+t.test('toRegExp: *.js matches foo.js', async t => {
+  const re = Glob.toRegExp('*.js')
+  t.ok(re instanceof RegExp, 'returns RegExp')
+  t.ok(re!.test('foo.js'), 'foo.js matches')
+  t.ok(re!.test('bar.js'), 'bar.js matches')
+  t.notOk(re!.test('foo.ts'), 'foo.ts does not match')
+  t.notOk(re!.test('a/b.js'), 'segment wildcard does not cross /')
+})
+
+t.test('toRegExp: does not anchor to start of string', async t => {
+  const re = Glob.toRegExp('foo.js')
+  t.ok(re!.test('foo.js'), 'foo.js matches')
+  t.ok(re!.test('a/foo.js'), 'a/foo.js matches')
+  t.notOk(re!.test('xfoo.js'), 'xfoo.js does not match')
+})
+
+t.test('toRegExp: fullMatch option anchors to both ends', async t => {
+  const re = Glob.toRegExp('src/*.js', { fullMatch: true })
+  t.ok(re!.test('src/foo.js'), 'src/foo.js matches')
+  t.notOk(re!.test('pre/src/foo.js'), 'pre/src/foo.js does not match')
+  t.notOk(re!.test('src/foo.jsx'), 'src/foo.jsx does not match')
+})
+
+t.test('toRegExp: brace expansion', async t => {
+  const re = Glob.toRegExp('*.{js,ts}')
+  t.ok(re!.test('foo.js'), 'foo.js matches')
+  t.ok(re!.test('bar.ts'), 'bar.ts matches')
+  t.notOk(re!.test('baz.txt'), 'baz.txt does not match')
+})
+
+t.test('toRegExp: character classes', async t => {
+  const re = Glob.toRegExp('[abc].js')
+  t.ok(re!.test('a.js'), 'a.js matches')
+  t.ok(re!.test('b.js'), 'b.js matches')
+  t.ok(re!.test('c.js'), 'c.js matches')
+  t.notOk(re!.test('z.js'), 'z.js does not match')
+})
+
+t.test('toRegExp: nocase option', async t => {
+  const sensitive = Glob.toRegExp('*.JS')
+  const insensitive = Glob.toRegExp('*.JS', { nocase: true })
+  t.ok(insensitive!.test('foo.js'), 'foo.js matches with nocase')
+  t.ok(insensitive!.test('foo.JS'), 'foo.JS matches with nocase')
+  t.notOk(sensitive!.test('foo.js'), 'foo.js does not match case-sensitive')
+})
+
+t.test('toRegExp: dot option', async t => {
+  const normal = Glob.toRegExp('*.js')
+  const withDot = Glob.toRegExp('*.js', { dot: true })
+  t.notOk(normal!.test('.hidden.js'), '.hidden.js does not match by default')
+  t.ok(withDot!.test('.hidden.js'), '.hidden.js matches with dot')
+  t.ok(withDot!.test('visible.js'), 'visible.js still matches with dot')
+})
+
+t.test('toRegExp: windowsPathsNoEscape option', async t => {
+  const re = Glob.toRegExp('src\\*.js', { windowsPathsNoEscape: true })
+  t.ok(re instanceof RegExp, 'returns RegExp with windows paths option')
+  t.ok(re!.test('src/foo.js'), 'backslash treated as / when windowsPathsNoEscape')
+})
+
+t.test('toRegExp: consistent with minimatch(pattern)(path) for fullMatch', async t => {
+  const cases: Array<[string, string[], object?]> = [
+    ['*.js', ['foo.js', 'bar.js', 'a.js', 'x.ts', 'a/b.js', 'a/b/c.js']],
+    ['**/*.js', ['foo.js', 'a/foo.js', 'a/b/c/foo.js', 'foo.ts']],
+    ['src/*.js', ['src/a.js', 'other/a.js', 'src/b/c.js']],
+    ['[abc].txt', ['a.txt', 'b.txt', 'z.txt', 'ab.txt']],
+    ['foo.?ar', ['foo.bar', 'foo.tar', 'foo.bear', 'foo.x/y']],
+    ['**/*.{js,ts}', ['a.js', 'x/y.ts', 'just.js', 'a.b.c']],
+  ]
+  for (const [pattern, paths, opts = {}] of cases) {
+    const re = Glob.toRegExp(pattern, { fullMatch: true, ...opts })
+    for (const p of paths) {
+      const expected = minimatch(p, pattern, opts)
+      t.equal(
+        re!.test(p),
+        expected,
+        `fullMatch: ${pattern} on ${p} matches minimatch`,
+      )
+    }
+  }
+})
+
+t.test('escapeRegExp: escapes regex metacharacters', async t => {
+  const escaped = Glob.escapeRegExp('a.b[c]d$e^f*g+h?i(j)k|l/m{n}')
+  const re = new RegExp('^' + escaped + '$')
+  t.ok(
+    re.test('a.b[c]d$e^f*g+h?i(j)k|l/m{n}'),
+    'literal string matches when escaped',
+  )
+  t.notOk(re.test('aXb[c]d$e^f*g+h?i(j)k|l/m{n}'), 'dot does not match any char')
+})
+
+t.test('escapeRegExp: distinguishes from glob escape', async t => {
+  const input = 'foo*.bar'
+  t.equal(
+    Glob.escapeRegExp(input),
+    'foo\\*\\.bar',
+    'escapeRegExp escapes both * and .',
+  )
+})
+
+t.test('toRegExp: also reachable through glob.toRegExp', async t => {
+  const re = glob.toRegExp('*.js')
+  t.ok(re instanceof RegExp, 'glob.toRegExp returns RegExp')
+  t.ok(re!.test('foo.js'), 'glob.toRegExp result works')
+})
+
+t.test('escapeRegExp: also reachable through glob.escapeRegExp', async t => {
+  t.equal(
+    glob.escapeRegExp('a.b'),
+    Glob.escapeRegExp('a.b'),
+    'glob.escapeRegExp equals Glob.escapeRegExp',
+  )
+})
+
