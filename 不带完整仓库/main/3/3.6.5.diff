+import type { MinimatchOptions } from 'minimatch'
+import { makeRe } from 'minimatch'
+
+/**
+ * Options for {@link toRegExp}
+ */
+export interface ToRegExpOptions extends MinimatchOptions {
+  /**
+   * When set to `true`, the returned RegExp will only match
+   * the entire string, anchoring to both the start (`^`) and
+   * end (`$`) of the string.
+   *
+   * When `false` (the default), the RegExp will not be anchored
+   * to the start of the string, but will still be anchored to
+   * the end. This means it will match any path that _ends with_
+   * a portion matching the pattern, making it useful for filtering
+   * path strings.
+   *
+   * For example, `toRegExp('*.js')` will match both `'foo.js'`
+   * and `'dir/foo.js'`, because the pattern is only anchored to
+   * the end. With `fullMatch: true`, it would only match
+   * `'foo.js'`.
+   *
+   * Example:
+   *
+   * ```ts
+   * // Filter an array of paths
+   * const paths = ['a/foo.js', 'b/bar.ts', 'c/baz.js']
+   * const re = glob.toRegExp('*.js')
+   * paths.filter(p => re.test(p)) // ['a/foo.js', 'c/baz.js']
+   *
+   * // Full match - only matches in the "current directory"
+   * const reFull = glob.toRegExp('*.js', { fullMatch: true })
+   * paths.filter(p => reFull.test(p)) // []
+   * ```
+   */
+  fullMatch?: boolean
+}
+
+/**
+ * Convert a glob pattern into a JavaScript RegExp object.
+ *
+ * This is useful when you need to use a glob pattern with tools
+ * that expect a regular expression, such as `Array.filter`,
+ * `String.replace`, or command-line tools like `sed`.
+ *
+ * The returned RegExp is built on top of `minimatch.makeRe`, but
+ * with adjustments to make it more practical for direct use on
+ * path strings:
+ *
+ * - By default, the RegExp is **not** anchored to the start of
+ *   the string (no `^`), but is anchored to the end (`$`). This
+ *   means it will match any path that _ends with_ a portion
+ *   matching the pattern.
+ * - Set {@link ToRegExpOptions.fullMatch} to `true` to anchor to
+ *   both the start and end, so the RegExp only matches when the
+ *   entire string satisfies the glob pattern.
+ *
+ * Supports the same options as `minimatch`, such as
+ * `windowsPathsNoEscape`, `nocase`, `dot`, `nobrace`, `noext`,
+ * `noglobstar`, and so on.
+ *
+ * Example:
+ *
+ * ```ts
+ * // Basic usage
+ * glob.toRegExp('*.js').test('foo.js') // true
+ * glob.toRegExp('*.js').test('dir/foo.js') // true
+ * glob.toRegExp('*.js', { fullMatch: true }).test('dir/foo.js') // false
+ *
+ * // Use with Array.filter
+ * const files = ['src/index.ts', 'src/util.js', 'README.md']
+ * files.filter(f => glob.toRegExp('*.ts').test(f)) // ['src/index.ts']
+ *
+ * // Use with sed-like replacement
+ * const re = glob.toRegExp('*.js')
+ * 'path/to/file.js'.replace(re, 'bundle.js') // 'path/to/bundle.js'
+ *
+ * // Case-insensitive matching
+ * glob.toRegExp('*.js', { nocase: true }).test('FOO.JS') // true
+ * ```
+ */
+export const toRegExp = (
+  pattern: string,
+  options: ToRegExpOptions = {},
+): RegExp => {
+  const { fullMatch = false, matchBase, ...mmOptions } = options
+
+  // When matchBase is true and the pattern has no slash, convert
+  // to **/{pattern} so that makeRe generates a regex that matches
+  // the basename in any directory. minimatch.makeRe does not
+  // handle matchBase itself; the minimatch() function does basename
+  // matching internally.
+  let effectivePattern = pattern
+  if (matchBase && !pattern.includes('/')) {
+    effectivePattern = `**/${pattern}`
+  }
+
+  const re = makeRe(effectivePattern, {
+    ...mmOptions,
+    nonegate: true,
+    nocomment: true,
+  })
+
+  if (!re) {
+    return /\b\B/
+  }
+
+  if (fullMatch) {
+    return re
+  }
+
+  let src = re.source
+  const flags = re.flags
+
+  // Replace the leading ^ anchor with a path-segment boundary
+  // that does NOT consume the / character. This allows the
+  // pattern to match at the start of the string or immediately
+  // after a /, so that e.g. *.js matches both foo.js and
+  // dir/foo.js, while ?.js still does not match ab.js.
+  // Using a lookbehind ensures that String.replace preserves
+  // the / before the matched portion.
+  if (src.startsWith('^')) {
+    src = '(?:^|(?<=\\/))' + src.substring(1)
+  }
+
+  // Keep the trailing $ anchor so the pattern matches the end
+  // of the string, preventing partial matches like *.js matching
+  // foo.jsx.
+
+  return new RegExp(src, flags)
+}
diff --git a/test/to-reg-exp.ts b/test/to-reg-exp.ts
