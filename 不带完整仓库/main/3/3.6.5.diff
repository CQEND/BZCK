+/**
+ * Escape all special regular expression characters in a string,
+ * so that it can be used as a literal match in a RegExp.
+ *
+ * This is distinct from {@link escape}, which escapes glob magic
+ * characters. Use `escapeRegExp` when constructing RegExp patterns
+ * from user input, and `escape` when constructing glob patterns.
+ *
+ * Example:
+ *
+ * ```ts
+ * // Escape a string for use in a RegExp
+ * const re = new RegExp(glob.escapeRegExp('file.js'))
+ * re.test('file.js') // true
+ * re.test('fileXjs') // false
+ * ```
+ */
+export const escapeRegExp = (s: string) =>
+  s.replace(/[-[\]{}()*+?.,\\^$|#\s]/g, '\\$&')
