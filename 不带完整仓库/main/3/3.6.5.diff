+++ b/test/to-reg-exp.ts
@@ -0,0 +1,292 @@
+import t from 'tap'
+import { escapeRegExp, toRegExp, glob } from '../dist/esm/index.js'
+import { minimatch } from 'minimatch'
+
+t.test('escapeRegExp', async t => {
+  t.equal(escapeRegExp('hello'), 'hello', 'no special chars')
+  t.equal(escapeRegExp('foo.js'), 'foo\\.js', 'escapes dot')
+  t.equal(escapeRegExp('a*b+c?'), 'a\\*b\\+c\\?', 'escapes wildcards and quantifiers')
+  t.equal(escapeRegExp('[abc]'), '\\[abc\\]', 'escapes character class')
+  t.equal(escapeRegExp('{a,b}'), '\\{a\\,b\\}', 'escapes braces and comma')
+  t.equal(escapeRegExp('a(b)c'), 'a\\(b\\)c', 'escapes parens')
+  t.equal(escapeRegExp('a^b$c'), 'a\\^b\\$c', 'escapes anchors')
+  t.equal(escapeRegExp('a|b'), 'a\\|b', 'escapes alternation')
+  t.equal(escapeRegExp('a\\b'), 'a\\\\b', 'escapes backslash')
+  t.equal(escapeRegExp('a b'), 'a\\ b', 'escapes whitespace')
+  t.equal(escapeRegExp('a-b'), 'a\\-b', 'escapes dash')
+  t.equal(escapeRegExp('a#b'), 'a\\#b', 'escapes hash')
+
+  t.test('escaped string can be used in RegExp', async t => {
+    const s = 'file.js'
+    const re = new RegExp(`^${escapeRegExp(s)}$`)
+    t.ok(re.test('file.js'), 'matches literal')
+    t.notOk(re.test('fileXjs'), 'does not match without dot')
+    t.notOk(re.test('file.jsx'), 'does not match partial')
+  })
+
+  t.test('available on glob object', async t => {
+    t.equal(glob.escapeRegExp('a.b'), 'a\\.b', 'glob.escapeRegExp works')
+    t.equal(glob.escapeRegExp, escapeRegExp, 'same function reference')
+  })
+})
+
+t.test('toRegExp basic wildcard', async t => {
+  const re = toRegExp('*.js')
+  t.ok(re.test('foo.js'), '*.js matches foo.js')
+  t.ok(re.test('bar.js'), '*.js matches bar.js')
+  t.notOk(re.test('foo.ts'), '*.js does not match foo.ts')
+  t.ok(re.test('dir/foo.js'), '*.js matches dir/foo.js (not fullMatch)')
+  t.notOk(re.test('foo.jsx'), '*.js does not match foo.jsx')
+})
+
+t.test('toRegExp fullMatch', async t => {
+  const re = toRegExp('*.js', { fullMatch: true })
+  t.ok(re.test('foo.js'), '*.js fullMatch matches foo.js')
+  t.notOk(re.test('dir/foo.js'), '*.js fullMatch does not match dir/foo.js')
+  t.notOk(re.test('foo.ts'), '*.js fullMatch does not match foo.ts')
+})
+
+t.test('toRegExp globstar', async t => {
+  const re = toRegExp('**/*.js')
+  t.ok(re.test('foo.js'), '**/*.js matches foo.js')
+  t.ok(re.test('dir/foo.js'), '**/*.js matches dir/foo.js')
+  t.ok(re.test('a/b/c/foo.js'), '**/*.js matches a/b/c/foo.js')
+  t.notOk(re.test('foo.ts'), '**/*.js does not match foo.ts')
+})
+
+t.test('toRegExp globstar fullMatch', async t => {
+  const re = toRegExp('**/*.js', { fullMatch: true })
+  t.ok(re.test('foo.js'), '**/*.js fullMatch matches foo.js')
+  t.ok(re.test('dir/foo.js'), '**/*.js fullMatch matches dir/foo.js')
+  t.ok(re.test('a/b/c/foo.js'), '**/*.js fullMatch matches a/b/c/foo.js')
+  t.notOk(re.test('foo.ts'), '**/*.js fullMatch does not match foo.ts')
+})
+
+t.test('toRegExp question mark', async t => {
+  const re = toRegExp('?.js')
+  t.ok(re.test('a.js'), '?.js matches a.js')
+  t.ok(re.test('b.js'), '?.js matches b.js')
+  t.notOk(re.test('ab.js'), '?.js does not match ab.js')
+  t.notOk(re.test('.js'), '?.js does not match .js')
+})
+
+t.test('toRegExp character class', async t => {
+  const re = toRegExp('[abc].js')
+  t.ok(re.test('a.js'), '[abc].js matches a.js')
+  t.ok(re.test('b.js'), '[abc].js matches b.js')
+  t.ok(re.test('c.js'), '[abc].js matches c.js')
+  t.notOk(re.test('d.js'), '[abc].js does not match d.js')
+})
+
+t.test('toRegExp negated character class', async t => {
+  const re = toRegExp('[!abc].js')
+  t.notOk(re.test('a.js'), '[!abc].js does not match a.js')
+  t.notOk(re.test('b.js'), '[!abc].js does not match b.js')
+  t.ok(re.test('d.js'), '[!abc].js matches d.js')
+})
+
+t.test('toRegExp brace expansion', async t => {
+  const re = toRegExp('{a,b,c}.js')
+  t.ok(re.test('a.js'), '{a,b,c}.js matches a.js')
+  t.ok(re.test('b.js'), '{a,b,c}.js matches b.js')
+  t.ok(re.test('c.js'), '{a,b,c}.js matches c.js')
+  t.notOk(re.test('d.js'), '{a,b,c}.js does not match d.js')
+})
+
+t.test('toRegExp brace expansion with fullMatch', async t => {
+  const re = toRegExp('{a,b,c}.js', { fullMatch: true })
+  t.ok(re.test('a.js'), '{a,b,c}.js fullMatch matches a.js')
+  t.notOk(re.test('dir/a.js'), '{a,b,c}.js fullMatch does not match dir/a.js')
+})
+
+t.test('toRegExp nocase option', async t => {
+  const re = toRegExp('*.js', { nocase: true })
+  t.ok(re.test('foo.js'), 'nocase matches lowercase')
+  t.ok(re.test('FOO.JS'), 'nocase matches uppercase')
+  t.ok(re.test('Foo.Js'), 'nocase matches mixed case')
+  t.equal(re.flags.includes('i'), true, 'has i flag')
+})
+
+t.test('toRegExp dot option', async t => {
+  // With fullMatch: false, the leading (?:^|/) boundary can bypass
+  // the globstar's dot-checking when matching after a /, so
+  // .hidden/foo.js matches **/*.js. Use fullMatch: true for
+  // strict dot-file semantics.
+  const reNoDot = toRegExp('**/*.js', { fullMatch: true })
+  t.notOk(reNoDot.test('.hidden/foo.js'), 'without dot, no dotdir match (fullMatch)')
+
+  const reDot = toRegExp('**/*.js', { dot: true, fullMatch: true })
+  t.ok(reDot.test('.hidden/foo.js'), 'with dot, dotdir match (fullMatch)')
+})
+
+t.test('toRegExp windowsPathsNoEscape', async t => {
+  const re = toRegExp('*.js', { windowsPathsNoEscape: true })
+  t.ok(re.test('foo.js'), 'windowsPathsNoEscape still matches')
+})
+
+t.test('toRegExp noglobstar', async t => {
+  // With noglobstar, ** is treated as *, so **/*.js becomes */*.js
+  // which matches exactly one directory level like dir/foo.js
+  const re = toRegExp('**/*.js', { noglobstar: true, fullMatch: true })
+  t.ok(re.test('dir/foo.js'), 'noglobstar **/*.js matches one level')
+  t.notOk(re.test('foo.js'), 'noglobstar **/*.js requires a directory')
+  t.notOk(re.test('a/b/c/foo.js'), 'noglobstar **/*.js does not match deep')
+})
+
+t.test('toRegExp nobrace', async t => {
+  const re = toRegExp('{a,b}.js', { nobrace: true })
+  t.notOk(re.test('a.js'), 'nobrace treats braces literally')
+  t.notOk(re.test('b.js'), 'nobrace treats braces literally')
+})
+
+t.test('toRegExp noext', async t => {
+  const re = toRegExp('+(a|b).js', { noext: true })
+  t.notOk(re.test('a.js'), 'noext treats extglob literally')
+})
+
+t.test('toRegExp returns RegExp instance', async t => {
+  const re = toRegExp('*.js')
+  t.ok(re instanceof RegExp, 'returns a RegExp')
+})
+
+t.test('toRegExp available on glob object', async t => {
+  const re = glob.toRegExp('*.js')
+  t.ok(re.test('foo.js'), 'glob.toRegExp works')
+  t.equal(typeof glob.toRegExp, 'function', 'glob.toRegExp is a function')
+})
+
+t.test('toRegExp invalid pattern returns never-matching regex', async t => {
+  const re = toRegExp('')
+  t.notOk(re.test('anything'), 'empty pattern never matches')
+  t.notOk(re.test(''), 'empty pattern does not match empty string')
+})
+
+t.test('toRegExp consistency with minimatch', async t => {
+  const patterns = [
+    '*.js',
+    '**/*.ts',
+    'src/**/*.js',
+    '{a,b,c}',
+    '[xyz]',
+    '?foo',
+    'a/b/c',
+    '**/node_modules/**',
+  ]
+
+  const paths = [
+    'foo.js',
+    'bar.ts',
+    'src/index.js',
+    'src/util.ts',
+    'a/b/c/foo.js',
+    'a',
+    'b',
+    'c',
+    'x',
+    'y',
+    'z',
+    '?foo',
+    'a/b/c',
+    'node_modules/react/index.js',
+    'src/node_modules/lodash/index.js',
+  ]
+
+  for (const pattern of patterns) {
+    const re = toRegExp(pattern, { fullMatch: true })
+    for (const path of paths) {
+      const minimatchResult = minimatch(path, pattern)
+      const toRegExpResult = re.test(path)
+      t.equal(
+        toRegExpResult,
+        minimatchResult,
+        `toRegExp(${JSON.stringify(pattern)}, {fullMatch:true}).test(${JSON.stringify(path)}) === minimatch(${JSON.stringify(path)}, ${JSON.stringify(pattern)})`,
+      )
+    }
+  }
+})
+
+t.test('toRegExp consistency with minimatch dot option', async t => {
+  const patterns = ['**/*.js', '*.js']
+  const paths = ['.hidden/foo.js', 'foo.js', '.dotfile']
+
+  for (const pattern of patterns) {
+    for (const dot of [true, false]) {
+      const re = toRegExp(pattern, { fullMatch: true, dot })
+      for (const path of paths) {
+        const minimatchResult = minimatch(path, pattern, { dot })
+        const toRegExpResult = re.test(path)
+        t.equal(
+          toRegExpResult,
+          minimatchResult,
+          `dot:${dot} toRegExp(${JSON.stringify(pattern)}).test(${JSON.stringify(path)}) === minimatch`,
+        )
+      }
+    }
+  }
+})
+
+t.test('toRegExp consistency with minimatch nocase option', async t => {
+  const pattern = '*.js'
+  const paths = ['foo.js', 'FOO.JS', 'Foo.Js']
+
+  for (const nocase of [true, false]) {
+    const re = toRegExp(pattern, { fullMatch: true, nocase })
+    for (const path of paths) {
+      const minimatchResult = minimatch(path, pattern, { nocase })
+      const toRegExpResult = re.test(path)
+      t.equal(
+        toRegExpResult,
+        minimatchResult,
+        `nocase:${nocase} toRegExp matches minimatch for ${path}`,
+      )
+    }
+  }
+})
+
+t.test('toRegExp use with Array.filter', async t => {
+  const files = [
+    'src/index.ts',
+    'src/util.js',
+    'README.md',
+    'lib/helper.js',
+    'test/index.ts',
+  ]
+  const re = toRegExp('*.ts')
+  t.same(
+    files.filter(f => re.test(f)),
+    ['src/index.ts', 'test/index.ts'],
+    'filters .ts files from all directories',
+  )
+
+  const reFull = toRegExp('*.ts', { fullMatch: true })
+  t.same(
+    files.filter(f => reFull.test(f)),
+    [],
+    'fullMatch only matches current directory',
+  )
+})
+
+t.test('toRegExp use with String.replace', async t => {
+  const re = toRegExp('*.js')
+  t.equal(
+    'path/to/file.js'.replace(re, 'bundle.js'),
+    'path/to/bundle.js',
+    'replaces .js with bundle.js',
+  )
+})
+
+t.test('toRegExp with matchBase', async t => {
+  const re = toRegExp('*.js', { matchBase: true, fullMatch: true })
+  t.ok(re.test('foo.js'), 'matchBase matches basename')
+  t.ok(re.test('dir/foo.js'), 'matchBase matches in subdirectory')
+  t.notOk(re.test('foo.ts'), 'matchBase does not match wrong extension')
+})
+
+t.test('toRegExp complex pattern', async t => {
+  const re = toRegExp('src/**/*.{ts,js}')
+  t.ok(re.test('src/index.ts'), 'matches src/index.ts')
+  t.ok(re.test('src/util.js'), 'matches src/util.js')
+  t.ok(re.test('src/deep/nested/file.ts'), 'matches deeply nested')
+  t.notOk(re.test('lib/index.ts'), 'does not match outside src')
+  t.notOk(re.test('src/style.css'), 'does not match wrong extension')
+})
