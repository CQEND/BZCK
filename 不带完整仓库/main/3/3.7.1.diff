+import type { Dirent } from 'node:fs'
+import { readFileSync, readdir, readdirSync } from 'node:fs'
+import { join } from 'node:path'
+import { performance } from 'node:perf_hooks'
+import t from 'tap'
+import { glob, globStream, globSync } from '../dist/esm/index.js'
+import type { GlobOptions } from '../src/glob.js'
+
+type AdaptiveCacheShape = {
+  patterns: Record<
+    string,
+    {
+      recent: string[][]
+      runs: number
+      signature: string
+    }
+  >
+  version: number
+}
+
+type ReaddirEntry = string | Buffer | Dirent<string> | Dirent<Buffer>
+
+type GlobCallOptions = Exclude<Parameters<typeof glob>[1], undefined>
+type GlobStreamOptions = Exclude<Parameters<typeof globStream>[1], undefined>
+
+const entryName = (entry: ReaddirEntry) =>
+  typeof entry === 'string' ? entry
+  : Buffer.isBuffer(entry) ? entry.toString('utf8')
+  : Buffer.isBuffer(entry.name) ? entry.name.toString('utf8')
+  : entry.name
+
+const sortEntries = <T extends ReaddirEntry>(entries: T[]) =>
+  [...entries].sort((a, b) => entryName(a).localeCompare(entryName(b), 'en'))
+
+const makeQueuedFs = () => {
+  const queue: (() => void)[] = []
+  let busy = false
+
+  const next = () => {
+    const job = queue.shift()
+    if (!job) {
+      busy = false
+      return
+    }
+    busy = true
+    job()
+  }
+
+  const schedule = (job: () => void) => {
+    queue.push(job)
+    if (!busy) {
+      next()
+    }
+  }
+
+  const delayFor = (path: string) =>
+    path.includes('/hot') ? 5
+    : path.includes('/cold-') ? 40
+    : 1
+
+  const queuedReaddir = ((
+    path: Parameters<typeof readdir>[0],
+    options: Parameters<typeof readdir>[1],
+    callback: Parameters<typeof readdir>[2],
+  ) => {
+    schedule(() => {
+      setTimeout(() => {
+        readdir(path, options, (error, entries) => {
+          const done = callback as (
+            error: NodeJS.ErrnoException | null,
+            entries: unknown,
+          ) => void
+          done(
+            error,
+            Array.isArray(entries) ? sortEntries(entries as ReaddirEntry[]) : entries,
+          )
+          next()
+        })
+      }, delayFor(String(path)))
+    })
+  }) as typeof readdir
+
+  const queuedReaddirSync = ((
+    path: Parameters<typeof readdirSync>[0],
+    options?: Parameters<typeof readdirSync>[1],
+  ) => {
+    const entries =
+      options === undefined ? readdirSync(path) : readdirSync(path, options)
+    return Array.isArray(entries) ? sortEntries(entries as ReaddirEntry[]) : entries
+  }) as typeof readdirSync
+
+  return {
+    readdir: queuedReaddir,
+    readdirSync: queuedReaddirSync,
+  } satisfies NonNullable<GlobOptions['fs']>
+}
+
+const adaptiveOptions = (cwd: string, overrides: Partial<GlobOptions> = {}) =>
+  ({
+    adaptive: true,
+    adaptiveMemory: 4,
+    cwd,
+    posix: true,
+    ...overrides,
+  }) as unknown as GlobCallOptions
+
+const adaptiveStreamOptions = (
+  cwd: string,
+  overrides: Partial<GlobOptions> = {},
+) =>
+  ({
+    adaptive: true,
+    adaptiveMemory: 4,
+    cwd,
+    fs: makeQueuedFs(),
+    posix: true,
+    ...overrides,
+  }) as unknown as GlobStreamOptions
+
+const firstResultTime = async (
+  cwd: string,
+  pattern: string,
+  options: Partial<GlobOptions> = {},
+) => {
+  const started = performance.now()
+  const stream = globStream(pattern, adaptiveStreamOptions(cwd, options))
+  const first = new Promise<number>((resolve, reject) => {
+    stream.once('data', () => resolve(performance.now() - started))
+    stream.once('error', reject)
+    stream.once('end', () => reject(new Error('stream ended without data')))
+  })
+  const allPromise = stream.collect()
+  return {
+    first: await first,
+    results: ((await allPromise) as string[]).sort((a, b) =>
+      a.localeCompare(b, 'en'),
+    ),
+  }
+}
+
+t.test('adaptive cache persists and keeps results identical', async t => {
+  const cwd = t.testdir({
+    src: {
+      hot: {
+        'entry-a.ts': '',
+        nested: {
+          'entry-b.ts': '',
+        },
+      },
+      'cold-a': {
+        noop: {
+          'entry-a.js': '',
+        },
+      },
+      'cold-b': {
+        noop: {
+          'entry-b.js': '',
+        },
+      },
+    },
+  })
+
+  const pattern = 'src/**/*.ts'
+  const expected = ['src/hot/entry-a.ts', 'src/hot/nested/entry-b.ts']
+
+  t.strictSame(
+    globSync(pattern, { cwd, posix: true }).sort((a, b) =>
+      a.localeCompare(b, 'en'),
+    ),
+    expected,
+  )
+
+  t.strictSame(
+    (await glob(pattern, adaptiveOptions(cwd, { adaptiveMemory: 2 })) as string[]).sort(
+      (a, b) => a.localeCompare(b, 'en'),
+    ),
+    expected,
+  )
+
+  const cache = JSON.parse(
+    readFileSync(join(cwd, '.glob_adapt_cache.json'), 'utf8'),
+  ) as AdaptiveCacheShape
+
+  t.equal(cache.version, 1)
+  t.equal(Object.keys(cache.patterns).length, 1)
+  t.match(
+    Object.values(cache.patterns)[0],
+    {
+      recent: [['src', 'src/hot', 'src/hot/nested']],
+      runs: 1,
+    },
+  )
+
+  t.strictSame(
+    (await glob(pattern, adaptiveOptions(cwd, { adaptiveMemory: 2 })) as string[]).sort(
+      (a, b) => a.localeCompare(b, 'en'),
+    ),
+    expected,
+  )
+  t.strictSame(
+    (await glob(pattern, adaptiveOptions(cwd, { adaptiveMemory: 2 })) as string[]).sort(
+      (a, b) => a.localeCompare(b, 'en'),
+    ),
+    expected,
+  )
+
+  const updated = JSON.parse(
+    readFileSync(join(cwd, '.glob_adapt_cache.json'), 'utf8'),
+  ) as AdaptiveCacheShape
+  const entry = Object.values(updated.patterns)[0]
+  t.equal(entry?.runs, 3)
+  t.equal(entry?.recent.length, 2)
+})
+
+t.test('adaptive ordering speeds up repeated and similar patterns', async t => {
+  const cwd = t.testdir({
+    src: {
+      'cold-a': {
+        nope: {
+          'a.js': '',
+        },
+      },
+      'cold-b': {
+        nope: {
+          'b.js': '',
+        },
+      },
+      'cold-c': {
+        nope: {
+          'c.js': '',
+        },
+      },
+      hot: {
+        'entry-a.ts': '',
+        deep: {
+          'entry-b.ts': '',
+        },
+      },
+    },
+  })
+
+  const repeatedPattern = 'src/**/*.ts'
+  const similarPattern = 'src/**/entry-*.ts'
+  const expected = ['src/hot/deep/entry-b.ts', 'src/hot/entry-a.ts']
+
+  const firstRun = await firstResultTime(cwd, repeatedPattern)
+  t.strictSame(firstRun.results, expected)
+
+  const secondRun = await firstResultTime(cwd, repeatedPattern)
+  t.strictSame(secondRun.results, expected)
+  t.ok(
+    firstRun.first > secondRun.first + 60,
+    `expected repeat speedup, saw ${firstRun.first}ms -> ${secondRun.first}ms`,
+  )
+
+  const similarRun = await firstResultTime(cwd, similarPattern)
+  t.strictSame(similarRun.results, expected)
+  t.ok(
+    similarRun.first < firstRun.first - 60,
+    `expected similar-pattern reuse, saw ${firstRun.first}ms -> ${similarRun.first}ms`,
+  )
+})
