+import { readFileSync, writeFileSync } from 'node:fs'
+import { join } from 'node:path'
+import type { Path } from 'path-scurry'
+
+interface CacheData {
+  [pattern: string]: {
+    [dir: string]: number
+  }
+}
+
+export class AdaptivePrewarmer {
+  private cachePath: string
+  private cache: CacheData
+  private maxMemory: number
+  private isAdaptive: boolean
+
+  constructor(cwd: string, adaptive: boolean = false, memory: number = 100) {
+    this.cachePath = join(cwd, '.glob_adapt_cache.json')
+    this.maxMemory = memory
+    this.isAdaptive = adaptive
+    this.cache = {}
+    if (this.isAdaptive) {
+      this.load()
+    }
+  }
+
+  load() {
+    try {
+      const data = readFileSync(this.cachePath, 'utf8')
+      this.cache = JSON.parse(data)
+    } catch (e) {
+      this.cache = {}
+    }
+  }
+
+
+
+  recordMatch(pattern: string, p: Path) {
+    if (!this.isAdaptive) return
+    if (!this.cache[pattern]) {
+      this.cache[pattern] = {}
+    }
+    
+    // Extract parent directories of matches
+    const dirs = new Set<string>()
+    let current: Path | undefined = p.parent
+    while (current && current.name && current.depth() >= 0) {
+      dirs.add(current.relativePosix())
+      current = current.parent
+    }
+
+    const patternCache = this.cache[pattern] as Record<string, number>
+    for (const d of dirs) {
+      patternCache[d] = (patternCache[d] || 0) + 1
+    }
+  }
+
+  save(pattern: string) {
+    if (!this.isAdaptive) return
+    
+    const currentScores = this.cache[pattern]
+    if (currentScores) {
+      // Age existing scores to prioritize recent runs
+      for (const d in currentScores) {
+        currentScores[d] = (currentScores[d] || 0) * 0.9
+      }
+
+      // Keep memory limit
+      const entries = Object.entries(currentScores).sort((a, b) => b[1] - a[1])
+      if (entries.length > this.maxMemory) {
+        this.cache[pattern] = Object.fromEntries(entries.slice(0, this.maxMemory))
+      }
+    }
+
+    try {
+      writeFileSync(this.cachePath, JSON.stringify(this.cache, null, 2))
+    } catch (e) {
+      // ignore
+    }
+  }
+
+  sort(pattern: string, paths: Path[]): Path[] {
+    if (!this.isAdaptive || !this.cache[pattern]) {
+      return paths
+    }
+    const scores = this.cache[pattern]
+    
+    // Explore-exploit: 10% explore (original order), 90% exploit (sort by score)
+    const isExplore = Math.random() < 0.1
+    if (isExplore) {
+      return paths
+    }
+
+    return [...paths].sort((a, b) => {
+      const sa = scores[a.relativePosix()] || 0
+      const sb = scores[b.relativePosix()] || 0
+      return sb - sa
+    })
+  }
+}
