diff --git a/test/adaptive.ts b/test/adaptive.ts
new file mode 100644
index 0000000..5591b75
--- /dev/null
+++ b/test/adaptive.ts
@@ -0,0 +1,113 @@
+import { existsSync } from 'node:fs'
+import { resolve } from 'node:path'
+import t from 'tap'
+import { globSync, glob } from '../dist/esm/index.js'
+
+// Adaptive pre-walker: an optimisation that reorders sub-walk targets based
+// on historical run statistics. The key invariant is that *final results must
+// be identical* to a plain walk — only the order in which directories are
+// scanned changes.
+
+const norm = (xs: string[]) => [...xs].sort((a, b) => a.localeCompare(b))
+
+t.test('adaptive walk produces identical results to plain walk', t => {
+  const cwd = t.testdir({
+    src: {
+      alpha: { 'a1.ts': '', 'a2.ts': '' },
+      beta: { 'b1.ts': '', 'b2.ts': '' },
+      gamma: { 'g1.ts': '' },
+    },
+    test: { 't1.ts': '', 't2.ts': '' },
+    docs: { 'd1.ts': '' },
+  })
+  const plain = globSync('**/*.ts', { cwd })
+  const adaptive = globSync('**/*.ts', {
+    cwd,
+    adaptive: true,
+    adaptiveCacheFile: false,
+  })
+  t.strictSame(norm(adaptive), norm(plain), 'same match set')
+  t.end()
+})
+
+t.test('adaptive async walk produces identical results', async t => {
+  const cwd = t.testdir({
+    a: { 'x.ts': '' },
+    b: { 'y.ts': '' },
+  })
+  const plain = await glob('**/*.ts', { cwd })
+  const adaptive = await glob('**/*.ts', {
+    cwd,
+    adaptive: true,
+    adaptiveCacheFile: false,
+  })
+  t.strictSame(norm(adaptive), norm(plain), 'same async match set')
+})
+
+t.test('repeated adaptive walks with a cache file still return full results', t => {
+  const cwd = t.testdir({
+    src: { x: { 'a.ts': '' }, y: { 'b.ts': '' } },
+    other: { 'c.ts': '' },
+  })
+  const cachePath = resolve(cwd, '.adaptive.json')
+  // First run warms the cache; subsequent runs must still return the
+  // complete match set.
+  const expected = norm(globSync('**/*.ts', { cwd }))
+  for (let i = 0; i < 5; i++) {
+    const res = globSync('**/*.ts', {
+      cwd,
+      adaptive: true,
+      adaptiveMemory: 3,
+      adaptiveCacheFile: cachePath,
+    })
+    t.strictSame(norm(res), expected, `run ${i} returns full match set`)
+  }
+  t.ok(existsSync(cachePath), 'cache file written to disk')
+  t.end()
+})
+
+t.test('adaptiveMemory bounds memory by dropping oldest-run statistics', t => {
+  const cwd = t.testdir({
+    src: { a: { 'a.ts': '' } },
+    dead: { b: { 'b.ts': '' } },
+  })
+  const cachePath = resolve(cwd, '.adaptive-small.json')
+  const expected = norm(globSync('**/*.ts', { cwd }))
+  for (let i = 0; i < 10; i++) {
+    const res = globSync('**/*.ts', {
+      cwd,
+      adaptive: true,
+      adaptiveMemory: 2,
+      adaptiveCacheFile: cachePath,
+    })
+    t.strictSame(norm(res), expected, `run ${i} result set unchanged`)
+  }
+  t.end()
+})
+
+t.test('narrow patterns (e.g. src/**/*.ts) do not break broad patterns later', t => {
+  const cwd = t.testdir({
+    src: { a: { 'a.ts': '' } },
+    docs: { 'd.ts': '' },
+  })
+  const cachePath = resolve(cwd, '.adaptive-mixed.json')
+  // Narrow walk first — only src/* is explored.
+  const narrow = globSync('src/**/*.ts', {
+    cwd,
+    adaptive: true,
+    adaptiveCacheFile: cachePath,
+  })
+  t.equal(narrow.length, 1, 'narrow pattern matches one file')
+  // Broad walk — must still reach docs/.
+  const broad = globSync('**/*.ts', {
+    cwd,
+    adaptive: true,
+    adaptiveCacheFile: cachePath,
+  })
+  t.strictSame(
+    norm(broad),
+    norm(globSync('**/*.ts', { cwd })),
+    'broad pattern after narrow still sees every match',
+  )
+  t.end()
