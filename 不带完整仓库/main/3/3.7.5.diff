diff --git a/src/adaptive-history-manager.ts b/src/adaptive-history-manager.ts
new file mode 100644
index 0000000..d41b5b4
--- /dev/null
+++ b/src/adaptive-history-manager.ts
@@ -0,0 +1,160 @@
+import { existsSync, readFileSync, writeFileSync } from 'node:fs'
+import { resolve } from 'node:path'
+
+export interface AdaptiveCacheData {
+  patterns: Map<string, PatternHistory>
+}
+
+export interface PatternHistory {
+  runCount: number
+  lastRun: number
+  dirMatchCounts: Map<string, number>
+}
+
+export interface PersistedCacheData {
+  version: number
+  patterns: Record<string, PersistedPatternHistory>
+}
+
+export interface PersistedPatternHistory {
+  runCount: number
+  lastRun: number
+  dirMatchCounts: Record<string, number>
+}
+
+export class AdaptiveHistoryManager {
+  #cachePath: string
+  #cache: AdaptiveCacheData
+  #memoryLimit: number
+
+  constructor(cachePath?: string, memoryLimit: number = 100) {
+    this.#memoryLimit = memoryLimit
+    this.#cachePath = cachePath || resolve(process.cwd(), '.glob_adapt_cache.json')
+    this.#cache = this.#loadCache()
+  }
+
+  #loadCache(): AdaptiveCacheData {
+    if (!existsSync(this.#cachePath)) {
+      return { patterns: new Map() }
+    }
+    try {
+      const raw = readFileSync(this.#cachePath, 'utf8')
+      const parsed: PersistedCacheData = JSON.parse(raw)
+      const patterns = new Map<string, PatternHistory>()
+      for (const [pattern, history] of Object.entries(parsed.patterns)) {
+        patterns.set(pattern, {
+          runCount: history.runCount,
+          lastRun: history.lastRun,
+          dirMatchCounts: new Map(Object.entries(history.dirMatchCounts)),
+        })
+      }
+      return { patterns }
+    } catch {
+      return { patterns: new Map() }
+    }
+  }
+
+  persist(): void {
+    const data: PersistedCacheData = {
+      version: 1,
+      patterns: {},
+    }
+    for (const [pattern, history] of this.#cache.patterns) {
+      data.patterns[pattern] = {
+        runCount: history.runCount,
+        lastRun: history.lastRun,
+        dirMatchCounts: Object.fromEntries(history.dirMatchCounts),
+      }
+    }
+    writeFileSync(this.#cachePath, JSON.stringify(data, null, 2))
+  }
+
+  recordRun(pattern: string, matchedDirs: string[]): void {
+    let history = this.#cache.patterns.get(pattern)
+    if (!history) {
+      history = {
+        runCount: 0,
+        lastRun: 0,
+        dirMatchCounts: new Map(),
+      }
+      this.#cache.patterns.set(pattern, history)
+    }
+    history.runCount++
+    history.lastRun = Date.now()
+    for (const dir of matchedDirs) {
+      const current = history.dirMatchCounts.get(dir) || 0
+      history.dirMatchCounts.set(dir, current + 1)
+    }
+    this.#pruneCache()
+  }
+
+  #pruneCache(): void {
+    if (this.#cache.patterns.size <= this.#memoryLimit) {
+      return
+    }
+    const sorted = [...this.#cache.patterns.entries()].sort(
+      (a, b) => a[1].lastRun - b[1].lastRun,
+    )
+    const toRemove = sorted.slice(0, sorted.length - this.#memoryLimit)
+    for (const [key] of toRemove) {
+      this.#cache.patterns.delete(key)
+    }
+  }
+
+  getPrioritizedDirs(pattern: string, candidateDirs: string[]): string[] {
+    const history = this.#cache.patterns.get(pattern)
+    if (!history || history.dirMatchCounts.size === 0) {
+      return [...candidateDirs]
+    }
+    const dirScores = new Map<string, number>()
+    for (const dir of candidateDirs) {
+      const score = history.dirMatchCounts.get(dir) || 0
+      dirScores.set(dir, score)
+    }
+    const highFreq: string[] = []
+    const lowFreq: string[] = []
+    for (const dir of candidateDirs) {
+      const score = dirScores.get(dir) || 0
+      if (score > 0) {
+        highFreq.push(dir)
+      } else {
+        lowFreq.push(dir)
+      }
+    }
+    highFreq.sort((a, b) => {
+      const scoreA = dirScores.get(a) || 0
+      const scoreB = dirScores.get(b) || 0
+      return scoreB - scoreA
+    })
+    return [...highFreq, ...lowFreq]
+  }
+
+  getExplorationRatio(): number {
+    return 0.1
+  }
+
+  getDirsForExploration(pattern: string, candidateDirs: string[]): string[] {
+    const history = this.#cache.patterns.get(pattern)
+    if (!history || history.dirMatchCounts.size === 0) {
+      return [...candidateDirs]
+    }
+    const unvisited: string[] = []
+    const visited: string[] = []
+    for (const dir of candidateDirs) {
+      if (history.dirMatchCounts.has(dir) && history.dirMatchCounts.get(dir)! > 0) {
+        visited.push(dir)
+      } else {
+        unvisited.push(dir)
+      }
+    }
+    return [...unvisited, ...visited]
+  }
+
+  clear(): void {
+    this.#cache = { patterns: new Map() }
+  }
+
+  getCache(): AdaptiveCacheData {
+    return this.#cache
+  }
+}
