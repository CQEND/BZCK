index 0000000..e1b1da5
--- /dev/null
+++ b/test/adaptive.ts
@@ -0,0 +1,405 @@
+import { existsSync, mkdirSync, readFileSync, readdirSync, rmSync, writeFileSync } from 'node:fs'
+import { tmpdir } from 'node:os'
+import { join } from 'node:path'
+import t from 'tap'
+import { Glob, AdaptiveHistoryManager } from '../dist/esm/index.js'
+
+const testDir = join(tmpdir(), 'glob-adaptive-test-' + Date.now())
+
+function setupTestDir() {
+  if (existsSync(testDir)) {
+    rmSync(testDir, { recursive: true, force: true })
+  }
+  mkdirSync(testDir, { recursive: true })
+
+  const dirs = [
+    'src/components',
+    'src/utils',
+    'src/helpers',
+    'src/services',
+    'src/models',
+    'test/unit',
+    'test/integration',
+    'docs/api',
+    'docs/guides',
+    'config',
+  ]
+
+  for (const dir of dirs) {
+    mkdirSync(join(testDir, dir), { recursive: true })
+    const fileCount = dir.startsWith('src') ? 5 : 2
+    for (let i = 0; i < fileCount; i++) {
+      writeFileSync(join(testDir, dir, `file${i}.ts`), `export const x = ${i}`)
+    }
+  }
+}
+
+function cleanupTestDir() {
+  if (existsSync(testDir)) {
+    rmSync(testDir, { recursive: true, force: true })
+  }
+}
+
+t.beforeEach(() => {
+  setupTestDir()
+})
+
+t.afterEach(() => {
+  cleanupTestDir()
+})
+
+t.test('adaptive option is accepted', async t => {
+  const g = new Glob('**/*.ts', {
+    cwd: testDir,
+    adaptive: true,
+  })
+  const results = await g.walk()
+  t.ok(Array.isArray(results), 'should return array')
+  t.ok(results.length > 0, 'should have results')
+})
+
+t.test('adaptive produces same results as non-adaptive', async t => {
+  const pattern = '**/*.ts'
+
+  const g1 = new Glob(pattern, { cwd: testDir })
+  const results1 = g1.walkSync()
+
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+  const g2 = new Glob(pattern, {
+    cwd: testDir,
+    adaptive: true,
+    adaptiveMemory: 50,
+  })
+  const results2 = g2.walkSync()
+
+  t.equal(results1.length, results2.length, 'should have same number of results')
+
+  const set1 = new Set(results1)
+  const set2 = new Set(results2)
+  t.equal(set1.size, set2.size, 'sets should be same size')
+
+  for (const r of results1) {
+    t.ok(set2.has(r), `should contain ${r}`)
+  }
+})
+
+t.test('adaptive records history and reorders directories', async t => {
+  const pattern = '**/*.ts'
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+
+  const historyManager = new AdaptiveHistoryManager(cachePath, 50)
+
+  for (let run = 0; run < 5; run++) {
+    const g = new Glob(pattern, {
+      cwd: testDir,
+      adaptive: true,
+      adaptiveHistoryManager: historyManager,
+    })
+    const results = g.walkSync()
+    t.ok(results.length > 0, `run ${run} should have results`)
+  }
+
+  t.ok(existsSync(cachePath), 'cache file should exist')
+
+  const cacheContent = JSON.parse(
+    readFileSync(cachePath, 'utf8'),
+  )
+  t.ok(cacheContent.patterns, 'should have patterns in cache')
+  t.ok(
+    Object.keys(cacheContent.patterns).length > 0,
+    'should have at least one pattern recorded',
+  )
+})
+
+t.test('adaptive prioritizes high-frequency directories', async t => {
+  const pattern = 'src/**/*.ts'
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+
+  const historyManager = new AdaptiveHistoryManager(cachePath, 50)
+
+  for (let run = 0; run < 10; run++) {
+    const g = new Glob(pattern, {
+      cwd: testDir,
+      adaptive: true,
+      adaptiveHistoryManager: historyManager,
+    })
+    g.walkSync()
+  }
+
+  const cache = historyManager.getCache()
+  const patternKey = pattern
+  const history = cache.patterns.get(patternKey)
+
+  t.ok(history, 'should have history for pattern')
+  t.equal(history?.runCount, 10, 'should have run count of 10')
+  t.ok(
+    history && history.dirMatchCounts.size > 0,
+    'should have recorded directory match counts',
+  )
+})
+
+t.test('adaptive with async walk', async t => {
+  const pattern = '**/*.ts'
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+
+  const historyManager = new AdaptiveHistoryManager(cachePath, 50)
+
+  const results: number[] = []
+  for (let run = 0; run < 3; run++) {
+    const g = new Glob(pattern, {
+      cwd: testDir,
+      adaptive: true,
+      adaptiveHistoryManager: historyManager,
+    })
+    const r = await g.walk()
+    results.push(r.length)
+  }
+
+  t.ok(results.every(r => r === results[0]), 'all runs should return same count')
+})
+
+t.test('adaptiveMemory limits cache size', async t => {
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+  const historyManager = new AdaptiveHistoryManager(cachePath, 3)
+
+  for (let i = 0; i < 10; i++) {
+    historyManager.recordRun(`pattern${i}`, [`dir${i}`])
+  }
+
+  const cache = historyManager.getCache()
+  t.ok(
+    cache.patterns.size <= 3,
+    `cache should have at most 3 patterns, has ${cache.patterns.size}`,
+  )
+})
+
+t.test('adaptive persists and loads from disk', async t => {
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+
+  const manager1 = new AdaptiveHistoryManager(cachePath, 50)
+  manager1.recordRun('**/*.ts', ['src/components', 'src/utils'])
+  manager1.persist()
+
+  const manager2 = new AdaptiveHistoryManager(cachePath, 50)
+  const cache = manager2.getCache()
+
+  const history = cache.patterns.get('**/*.ts')
+  t.ok(history, 'should load pattern from disk')
+  t.equal(history?.runCount, 1, 'should have correct run count')
+  t.equal(
+    history?.dirMatchCounts.get('src/components'),
+    1,
+    'should have recorded dir match count',
+  )
+})
+
+t.test('adaptive handles empty results', async t => {
+  const pattern = '**/*.xyz'
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+
+  const historyManager = new AdaptiveHistoryManager(cachePath, 50)
+
+  const g = new Glob(pattern, {
+    cwd: testDir,
+    adaptive: true,
+    adaptiveHistoryManager: historyManager,
+  })
+  const results = g.walkSync()
+
+  t.equal(results.length, 0, 'should have no results')
+})
+
+t.test('adaptive with multiple patterns', async t => {
+  const patterns = ['src/**/*.ts', 'test/**/*.ts']
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+
+  const historyManager = new AdaptiveHistoryManager(cachePath, 50)
+
+  for (const pattern of patterns) {
+    const g = new Glob(pattern, {
+      cwd: testDir,
+      adaptive: true,
+      adaptiveHistoryManager: historyManager,
+    })
+    g.walkSync()
+  }
+
+  const cache = historyManager.getCache()
+  t.equal(
+    cache.patterns.size,
+    2,
+    'should have recorded both patterns',
+  )
+})
+
+t.test('adaptive exploration strategy', async t => {
+  const pattern = '**/*.ts'
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+
+  const historyManager = new AdaptiveHistoryManager(cachePath, 50)
+
+  for (let run = 0; run < 20; run++) {
+    const g = new Glob(pattern, {
+      cwd: testDir,
+      adaptive: true,
+      adaptiveHistoryManager: historyManager,
+    })
+    g.walkSync()
+  }
+
+  const cache = historyManager.getCache()
+  const history = cache.patterns.get(pattern)
+
+  t.ok(history, 'should have history')
+  t.ok(
+    history && history.dirMatchCounts.size > 0,
+    'should have recorded multiple directories',
+  )
+
+  const dirs = [...(history?.dirMatchCounts.keys() || [])]
+  t.ok(dirs.length > 0, 'should have tracked directories')
+})
+
+t.test('adaptive with signal abort', async t => {
+  const pattern = '**/*.ts'
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+
+  const historyManager = new AdaptiveHistoryManager(cachePath, 50)
+  const controller = new AbortController()
+
+  const g = new Glob(pattern, {
+    cwd: testDir,
+    adaptive: true,
+    adaptiveHistoryManager: historyManager,
+    signal: controller.signal,
+  })
+
+  controller.abort()
+
+  try {
+    await g.walk()
+    t.fail('should have thrown')
+  } catch (e: any) {
+    t.ok(e, 'should throw on abort')
+  }
+})
+
+t.test('adaptive sync with signal abort', async t => {
+  const pattern = '**/*.ts'
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+
+  const historyManager = new AdaptiveHistoryManager(cachePath, 50)
+  const controller = new AbortController()
+
+  const g = new Glob(pattern, {
+    cwd: testDir,
+    adaptive: true,
+    adaptiveHistoryManager: historyManager,
+    signal: controller.signal,
+  })
+
+  controller.abort()
+
+  try {
+    g.walkSync()
+    t.fail('should have thrown')
+  } catch (e: any) {
+    t.ok(e, 'should throw on abort')
+  }
+})
+
+t.test('adaptive reordering produces correct results', async t => {
+  const pattern = 'src/**/*.ts'
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+
+  const historyManager = new AdaptiveHistoryManager(cachePath, 50)
+
+  const resultsWithoutAdaptive = new Glob(pattern, {
+    cwd: testDir,
+  }).walkSync()
+
+  for (let run = 0; run < 5; run++) {
+    const g = new Glob(pattern, {
+      cwd: testDir,
+      adaptive: true,
+      adaptiveHistoryManager: historyManager,
+    })
+    const resultsWithAdaptive = g.walkSync()
+
+    t.equal(
+      resultsWithAdaptive.length,
+      resultsWithoutAdaptive.length,
+      `run ${run} should have same count as non-adaptive`,
+    )
+
+    const setWithout = new Set(resultsWithoutAdaptive)
+    for (const r of resultsWithAdaptive) {
+      t.ok(setWithout.has(r), `should contain ${r}`)
+    }
+  }
+})
+
+t.test('adaptive history manager clear', async t => {
+  const cachePath = join(testDir, '.glob_adapt_cache.json')
+  const historyManager = new AdaptiveHistoryManager(cachePath, 50)
+
+  historyManager.recordRun('**/*.ts', ['src'])
+  historyManager.persist()
+
+  historyManager.clear()
+
+  const cache = historyManager.getCache()
+  t.equal(cache.patterns.size, 0, 'cache should be empty after clear')
